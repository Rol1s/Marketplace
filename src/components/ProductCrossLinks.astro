---
import { getSteelGradesForProduct, getCities } from '@lib/data';

interface Props {
  productSlug: string;
  itemSlug: string;
  productType: string;
  basePath: string;
}

const { productSlug, itemSlug, productType, basePath } = Astro.props;

const grades = getSteelGradesForProduct(productSlug);
const cities = getCities().slice(0, 6);
---

{grades.length > 0 && (
  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Марки стали для {productType}</h2>
    <div class="flex flex-wrap gap-2">
      {grades.map((g) => (
        <a href={`${basePath}${itemSlug}/${g.slug}/`}
           class="inline-block px-3 py-2 rounded-lg text-sm border border-border bg-surface hover:border-primary transition-colors">
          {g.name}
        </a>
      ))}
    </div>
  </section>
)}

<section class="mb-8">
  <h2 class="text-lg font-bold text-primary mb-3">Купить {productType} в городе</h2>
  <div class="flex flex-wrap gap-2">
    {cities.map((city) => (
      <a href={`/${city.slug}/`}
         class="inline-block px-3 py-2 rounded-lg text-sm border border-border bg-surface hover:border-primary transition-colors">
        {city.name}
      </a>
    ))}
    <a href="/moskva/" class="inline-block px-3 py-2 rounded-lg text-xs text-text-muted hover:text-primary transition-colors">
      Все города...
    </a>
  </div>
</section>
