---
import { SITE, SECTIONS } from '@/config/site';
import { getCities } from '@lib/data';

const cities = getCities().slice(0, 10);
---

<header class="bg-primary text-white sticky top-0 z-50 shadow-md">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="text-xl font-bold tracking-tight hover:opacity-90 transition-opacity flex-shrink-0">
        {SITE.name}
      </a>

      <nav class="hidden lg:flex items-center gap-0.5 ml-6">
        <!-- Сортамент dropdown -->
        <div class="relative group">
          <button class="px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10 transition-colors flex items-center gap-1">
            Сортамент
            <svg class="w-3 h-3 opacity-60 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-1 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-150 z-50">
            <div class="bg-white text-text rounded-lg shadow-xl border border-border py-2 min-w-[200px]">
              {SECTIONS.map((s) => (
                <a href={`/${s.slug}/`} class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">
                  {s.name}
                </a>
              ))}
              <div class="border-t border-border my-1"></div>
              <a href="/sortament/" class="block px-4 py-2 text-sm font-medium text-primary hover:bg-primary/5 transition-colors">
                Весь сортамент →
              </a>
            </div>
          </div>
        </div>

        <!-- Б/у металл dropdown -->
        <div class="relative group">
          <button class="px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10 transition-colors flex items-center gap-1">
            Б/у металл
            <svg class="w-3 h-3 opacity-60 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-1 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-150 z-50">
            <div class="bg-white text-text rounded-lg shadow-xl border border-border py-2 min-w-[200px]">
              <a href="/bu-metall/truby/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Трубы б/у</a>
              <a href="/bu-metall/shvellery/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Швеллеры б/у</a>
              <a href="/bu-metall/dvutavry/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Двутавры б/у</a>
              <a href="/bu-metall/listy/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Листы б/у</a>
              <a href="/bu-metall/ugolki/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Уголки б/у</a>
              <a href="/bu-metall/shpunt/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Шпунт б/у</a>
              <div class="border-t border-border my-1"></div>
              <a href="/bu-metall/" class="block px-4 py-2 text-sm font-medium text-primary hover:bg-primary/5 transition-colors">
                Весь б/у каталог →
              </a>
            </div>
          </div>
        </div>

        <!-- Новые категории dropdown -->
        <div class="relative group">
          <button class="px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10 transition-colors flex items-center gap-1">
            Ещё
            <svg class="w-3 h-3 opacity-60 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-1 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-150 z-50">
            <div class="bg-white text-text rounded-lg shadow-xl border border-border py-2 min-w-[240px]">
              <a href="/armatura/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Арматура ГОСТ 34028</a>
              <a href="/profilnaya-truba/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Профильная труба</a>
              <a href="/truby-besshovnye/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Трубы бесшовные ГОСТ 8732</a>
              <a href="/truby-vgp/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Трубы ВГП ГОСТ 3262</a>
              <a href="/krug/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Круг ГОСТ 2590</a>
              <a href="/kvadrat/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Квадрат ГОСТ 2591</a>
              <a href="/polosa/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Полоса ГОСТ 103</a>
              <a href="/dvutavry-8239/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Двутавры ГОСТ 8239</a>
              <a href="/shvellery-gnutye/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">Швеллеры гнутые ГОСТ 8278</a>
              <div class="border-t border-border my-1"></div>
              <a href="/truby/izolyaciya-vus/" class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">ВУС изоляция</a>
              <a href="/stati/" class="block px-4 py-2 text-sm font-medium text-primary hover:bg-primary/5 transition-colors">Статьи →</a>
              <a href="/sravnenie/" class="block px-4 py-2 text-sm font-medium text-primary hover:bg-primary/5 transition-colors">Сравнение ГОСТов →</a>
            </div>
          </div>
        </div>

        <!-- Города dropdown -->
        <div class="relative group">
          <button class="px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10 transition-colors flex items-center gap-1">
            Города
            <svg class="w-3 h-3 opacity-60 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full right-0 pt-1 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-150 z-50">
            <div class="bg-white text-text rounded-lg shadow-xl border border-border py-2 min-w-[220px] max-h-[400px] overflow-y-auto">
              {cities.map((c) => (
                <a href={`/${c.slug}/`} class="block px-4 py-2 text-sm hover:bg-primary/5 hover:text-primary transition-colors">
                  {c.name}
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Инструменты -->
        <a href="/calculator/" class="px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10 transition-colors">
          Калькулятор
        </a>

        <a href="/marki-stali/" class="px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10 transition-colors">
          Марки стали
        </a>

        <!-- CTA -->
        <a
          href="/zayavka/"
          class="ml-2 px-4 py-2 text-sm font-semibold bg-accent rounded-md hover:bg-accent-light transition-colors"
        >
          Заявка
        </a>
      </nav>

      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-md hover:bg-white/10"
        aria-label="Открыть меню"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <nav id="mobile-menu" class="lg:hidden hidden pb-4 divide-y divide-white/10">
      <!-- Сортамент -->
      <div class="py-2">
        <button class="mobile-accordion w-full flex items-center justify-between px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10">
          Сортамент
          <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-content hidden pl-4 mt-1 space-y-1">
          {SECTIONS.map((s) => (
            <a href={`/${s.slug}/`} class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">{s.name}</a>
          ))}
        </div>
      </div>

      <!-- Б/у -->
      <div class="py-2">
        <button class="mobile-accordion w-full flex items-center justify-between px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10">
          Б/у металл
          <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-content hidden pl-4 mt-1 space-y-1">
          <a href="/bu-metall/truby/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Трубы б/у</a>
          <a href="/bu-metall/shvellery/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Швеллеры б/у</a>
          <a href="/bu-metall/dvutavry/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Двутавры б/у</a>
          <a href="/bu-metall/listy/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Листы б/у</a>
          <a href="/bu-metall/ugolki/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Уголки б/у</a>
          <a href="/bu-metall/shpunt/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Шпунт б/у</a>
        </div>
      </div>

      <!-- Ещё категории -->
      <div class="py-2">
        <button class="mobile-accordion w-full flex items-center justify-between px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10">
          Ещё категории
          <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-content hidden pl-4 mt-1 space-y-1">
          <a href="/armatura/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Арматура</a>
          <a href="/profilnaya-truba/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Профильная труба</a>
          <a href="/truby-besshovnye/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Трубы бесшовные</a>
          <a href="/truby-vgp/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Трубы ВГП</a>
          <a href="/krug/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Круг</a>
          <a href="/kvadrat/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Квадрат</a>
          <a href="/polosa/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Полоса</a>
          <a href="/dvutavry-8239/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Двутавры ГОСТ 8239</a>
          <a href="/shvellery-gnutye/" class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">Швеллеры гнутые</a>
        </div>
      </div>

      <!-- Прямые ссылки -->
      <div class="py-2 space-y-1">
        <a href="/truby/izolyaciya-vus/" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10">ВУС изоляция</a>
        <a href="/stati/" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10">Статьи</a>
        <a href="/sravnenie/" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10">Сравнение ГОСТов</a>
        <a href="/calculator/" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10">Калькулятор</a>
        <a href="/marki-stali/" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10">Марки стали</a>
      </div>

      <!-- Города -->
      <div class="py-2">
        <button class="mobile-accordion w-full flex items-center justify-between px-3 py-2 text-sm font-medium rounded-md hover:bg-white/10">
          Города
          <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="mobile-accordion-content hidden pl-4 mt-1 space-y-1">
          {cities.map((c) => (
            <a href={`/${c.slug}/`} class="block px-3 py-1.5 text-sm text-white/80 hover:text-white rounded-md hover:bg-white/5">{c.name}</a>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="pt-3">
        <a href="/zayavka/" class="block px-4 py-3 text-sm font-semibold bg-accent text-center rounded-md hover:bg-accent-light">
          Оставить заявку
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  document.querySelectorAll('.mobile-accordion').forEach((btn) => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling as HTMLElement | null;
      const icon = btn.querySelector('svg');
      if (!content) return;
      content.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
