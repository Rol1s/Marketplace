---
interface Props {
  width: number;
  height: number;
  wallThickness: number;
  label?: string;
}

const { width, height, wallThickness, label } = Astro.props;

const svgW = 300;
const svgH = 280;
const pad = 50;

const maxDim = Math.max(width, height);
const scale = (svgH - pad * 2) / maxDim;

const drawW = width * scale;
const drawH = height * scale;
const drawT = wallThickness * scale;

const cx = svgW / 2 - 10;
const cy = svgH / 2;

const left = cx - drawW / 2;
const top = cy - drawH / 2;
const r = Math.min(drawT * 1.5, 6);
---

<div class="flex flex-col items-center">
  <svg
    viewBox={`0 0 ${svgW} ${svgH}`}
    class="w-full max-w-[300px]"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <marker id="rt-arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6" fill="none" stroke="#1e3a5f" stroke-width="1"/>
      </marker>
    </defs>

    <!-- Outer rectangle -->
    <rect x={left} y={top} width={drawW} height={drawH}
      rx={r} ry={r} fill="#c8ced6" stroke="#1e3a5f" stroke-width="1.2"/>

    <!-- Inner rectangle (hole) -->
    <rect x={left + drawT} y={top + drawT} width={drawW - 2 * drawT} height={drawH - 2 * drawT}
      rx={Math.max(r - drawT * 0.5, 1)} fill="white" stroke="#4a5565" stroke-width="1"/>

    <!-- Dimension: height (left) -->
    <line x1={left - 20} y1={top} x2={left - 20} y2={top + drawH}
      stroke="#1e3a5f" stroke-width="0.8" marker-start="url(#rt-arr)" marker-end="url(#rt-arr)"/>
    <line x1={left - 4} y1={top} x2={left - 24} y2={top} stroke="#1e3a5f" stroke-width="0.5"/>
    <line x1={left - 4} y1={top + drawH} x2={left - 24} y2={top + drawH} stroke="#1e3a5f" stroke-width="0.5"/>
    <text
      x={left - 25}
      y={cy + 4}
      text-anchor="middle"
      fill="#1e3a5f"
      font-size="12"
      font-weight="600"
      transform={`rotate(-90, ${left - 25}, ${cy})`}
    >{height}</text>

    <!-- Dimension: width (bottom) -->
    <line x1={left} y1={top + drawH + 18} x2={left + drawW} y2={top + drawH + 18}
      stroke="#1e3a5f" stroke-width="0.8" marker-start="url(#rt-arr)" marker-end="url(#rt-arr)"/>
    <line x1={left} y1={top + drawH + 4} x2={left} y2={top + drawH + 22} stroke="#1e3a5f" stroke-width="0.5"/>
    <line x1={left + drawW} y1={top + drawH + 4} x2={left + drawW} y2={top + drawH + 22} stroke="#1e3a5f" stroke-width="0.5"/>
    <text x={cx} y={top + drawH + 32} text-anchor="middle" fill="#1e3a5f" font-size="12" font-weight="600">{width}</text>

    <!-- Dimension: wall thickness (right side) -->
    {drawT > 2 && (
      <>
        <line x1={left + drawW - drawT / 2} y1={top + 4} x2={left + drawW + 20} y2={top - 10}
          stroke="#64748b" stroke-width="0.6"/>
        <circle cx={left + drawW - drawT / 2} cy={top + 4} r="1.5" fill="#64748b"/>
        <text x={left + drawW + 22} y={top - 6} text-anchor="start" fill="#64748b" font-size="10" font-weight="600">
          t={wallThickness}
        </text>
      </>
    )}

    <!-- Label -->
    <text x={svgW / 2} y={svgH - 4} text-anchor="middle" fill="#64748b" font-size="10">
      {label || `Профтруба ${width}×${height}×${wallThickness}`}
    </text>
  </svg>
</div>
