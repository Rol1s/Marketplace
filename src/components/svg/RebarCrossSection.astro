---
interface Props {
  diameter: number;
  label?: string;
}

const { diameter, label } = Astro.props;

const svgW = 280;
const svgH = 260;
const maxR = 85;
const scale = maxR / (diameter / 2);
const drawR = (diameter / 2) * scale;
const cx = svgW / 2;
const cy = svgH / 2 - 10;
const dimY = cy + drawR + 24;

const ribCount = Math.min(Math.max(Math.floor(diameter / 2), 6), 16);
---

<div class="flex flex-col items-center">
  <svg
    viewBox={`0 0 ${svgW} ${svgH}`}
    class="w-full max-w-[280px]"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <radialGradient id="reb-grad" cx="35%" cy="35%">
        <stop offset="0%" stop-color="#c8ced6"/>
        <stop offset="100%" stop-color="#6b7380"/>
      </radialGradient>
      <marker id="reb-arr" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6" fill="none" stroke="#1e3a5f" stroke-width="1"/>
      </marker>
    </defs>

    <!-- Main circle -->
    <circle cx={cx} cy={cy} r={drawR} fill="url(#reb-grad)" stroke="#1e3a5f" stroke-width="1.5"/>

    <!-- Ribs (decorative lines on perimeter) -->
    {Array.from({ length: ribCount }).map((_, i) => {
      const angle = (i / ribCount) * Math.PI * 2;
      const x1 = cx + Math.cos(angle) * (drawR - 3);
      const y1 = cy + Math.sin(angle) * (drawR - 3);
      const x2 = cx + Math.cos(angle) * (drawR + 4);
      const y2 = cy + Math.sin(angle) * (drawR + 4);
      return (
        <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="#3a4555" stroke-width="1.5" stroke-linecap="round"/>
      );
    })}

    <!-- Two longitudinal ribs (horizontal line through center) -->
    <line x1={cx - drawR + 2} y1={cy} x2={cx + drawR - 2} y2={cy}
      stroke="#4a5565" stroke-width="1.2" stroke-dasharray="4 3"/>

    <!-- Diameter dimension -->
    <line x1={cx - drawR - 4} y1={dimY} x2={cx - 14} y2={dimY}
      stroke="#1e3a5f" stroke-width="0.8" marker-start="url(#reb-arr)"/>
    <line x1={cx + 14} y1={dimY} x2={cx + drawR + 4} y2={dimY}
      stroke="#1e3a5f" stroke-width="0.8" marker-end="url(#reb-arr)"/>
    <line x1={cx - drawR - 4} y1={cy + drawR + 8} x2={cx - drawR - 4} y2={dimY + 4} stroke="#1e3a5f" stroke-width="0.5"/>
    <line x1={cx + drawR + 4} y1={cy + drawR + 8} x2={cx + drawR + 4} y2={dimY + 4} stroke="#1e3a5f" stroke-width="0.5"/>
    <text x={cx} y={dimY + 4} text-anchor="middle" fill="#1e3a5f" font-size="13" font-weight="600">
      ⌀{diameter}
    </text>

    <!-- Label -->
    <text x={svgW / 2} y={svgH - 4} text-anchor="middle" fill="#64748b" font-size="10">
      {label || `Арматура ⌀${diameter}, ГОСТ 34028-2016`}
    </text>
  </svg>
</div>
