---
import { SITE, SECTIONS } from '@/config/site';
import { getCities } from '@lib/data';

const year = new Date().getFullYear();
const cities = getCities();
const topCities = cities.slice(0, 10);
---

<footer class="bg-primary text-white/80 mt-16">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- О компании -->
      <div class="col-span-2 md:col-span-1">
        <h3 class="text-lg font-bold text-white mb-3">{SITE.name}</h3>
        <p class="text-sm leading-relaxed mb-4">
          ГОСТ-справочник металлопроката: калькулятор веса, таблицы характеристик, 52 000+ страниц сортамента.
        </p>
        <a href="/zayavka/" class="inline-block px-4 py-2 bg-accent text-white text-sm font-semibold rounded-md hover:bg-accent-light transition-colors">
          Оставить заявку
        </a>
      </div>

      <!-- Справочник -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Сортамент</h4>
        <ul class="space-y-2">
          {SECTIONS.map((s) => (
            <li>
              <a href={`/${s.slug}/`} class="text-sm hover:text-white transition-colors">{s.name}</a>
            </li>
          ))}
        </ul>

        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mt-5 mb-3">Спецразделы</h4>
        <ul class="space-y-2">
          <li><a href="/bu-metall/" class="text-sm hover:text-white transition-colors">Б/у металлопрокат</a></li>
          <li><a href="/truby/izolyaciya-vus/" class="text-sm hover:text-white transition-colors">Трубы в ВУС изоляции</a></li>
          <li><a href="/marki-stali/" class="text-sm hover:text-white transition-colors">Марки стали</a></li>
          <li><a href="/calculator/" class="text-sm hover:text-white transition-colors">Калькулятор веса</a></li>
        </ul>
      </div>

      <!-- Б/у металл -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Б/у металл</h4>
        <ul class="space-y-2">
          <li><a href="/bu-metall/truby/" class="text-sm hover:text-white transition-colors">Трубы б/у</a></li>
          <li><a href="/bu-metall/shvellery/" class="text-sm hover:text-white transition-colors">Швеллеры б/у</a></li>
          <li><a href="/bu-metall/dvutavry/" class="text-sm hover:text-white transition-colors">Двутавры б/у</a></li>
          <li><a href="/bu-metall/listy/" class="text-sm hover:text-white transition-colors">Листы б/у</a></li>
          <li><a href="/bu-metall/ugolki/" class="text-sm hover:text-white transition-colors">Уголки б/у</a></li>
          <li><a href="/bu-metall/shpunt/" class="text-sm hover:text-white transition-colors">Шпунт б/у</a></li>
        </ul>
      </div>

      <!-- Города -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Города</h4>
        <ul class="space-y-2">
          {topCities.map((c) => (
            <li>
              <a href={`/${c.slug}/`} class="text-sm hover:text-white transition-colors">{c.name}</a>
            </li>
          ))}
        </ul>
        {cities.length > 10 && (
          <p class="mt-2 text-xs text-white/50">и ещё {cities.length - 10} городов</p>
        )}
      </div>
    </div>

    <div class="border-t border-white/20 mt-8 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/50">
      <span>&copy; {year} {SITE.name}. Данные предоставлены в справочных целях.</span>
      <span>{SITE.domain}</span>
    </div>
  </div>
</footer>
