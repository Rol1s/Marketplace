---
interface RelatedItem {
  label: string;
  href: string;
}

interface Props {
  title?: string;
  items: RelatedItem[];
}

const { title = 'Смотрите также', items } = Astro.props;
---

{items.length > 0 && (
  <section class="mt-10">
    <h2 class="text-xl font-bold text-primary mb-4">{title}</h2>
    <div class="flex flex-wrap gap-2">
      {items.map((item) => (
        <a
          href={item.href}
          class="inline-block px-3 py-1.5 text-sm bg-surface rounded-md border border-border hover:border-primary hover:text-primary transition-colors"
        >
          {item.label}
        </a>
      ))}
    </div>
  </section>
)}
