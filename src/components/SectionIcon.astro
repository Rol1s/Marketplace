---
interface Props {
  slug: string;
  class?: string;
}

const { slug, class: cls = 'w-10 h-10' } = Astro.props;
---

<div class={`${cls} text-current`}>
  {slug === 'truby' && (
    <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <circle cx="20" cy="20" r="14"/><circle cx="20" cy="20" r="9"/>
    </svg>
  )}
  {slug === 'shvellery' && (
    <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M10 6h6v28h-6M16 6h14M16 34h14"/>
    </svg>
  )}
  {slug === 'dvutavry' && (
    <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M10 6h20M10 34h20M20 6v28"/><path d="M17 6v4M23 6v4M17 30v4M23 30v4"/>
    </svg>
  )}
  {slug === 'listy' && (
    <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
      <rect x="6" y="10" width="28" height="20" rx="1"/><line x1="6" y1="14" x2="34" y2="14"/>
    </svg>
  )}
  {slug === 'ugolki' && (
    <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M8 8v26h4V12h22v-4H8z"/>
    </svg>
  )}
  {slug === 'shpunt' && (
    <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
      <path d="M6 8h6l4 12-4 12H6M22 8h6l4 12-4 12h-6"/><line x1="12" y1="20" x2="22" y2="20"/>
    </svg>
  )}
</div>
