---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<section class="mt-10">
  <h2 class="text-xl font-bold text-primary mb-4">Частые вопросы</h2>
  <div class="space-y-3">
    {items.map((item) => (
      <details class="group bg-surface border border-border rounded-lg">
        <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-sm font-medium text-text hover:text-primary transition-colors">
          {item.question}
          <svg class="w-4 h-4 shrink-0 ml-2 text-text-muted transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
          </svg>
        </summary>
        <div class="px-5 pb-4 text-sm text-text-muted leading-relaxed border-t border-border/50 pt-3">
          <Fragment set:html={item.answer} />
        </div>
      </details>
    ))}
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
