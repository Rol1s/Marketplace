---
import Gost from '@layouts/Gost.astro';
import GostTable from '@components/GostTable.astro';
import RelatedItems from '@components/RelatedItems.astro';
import WeightCalculator from '@components/WeightCalculator';
import { getSheetPiles } from '@lib/data';
import { shpuntMeta } from '@lib/seo';
import ProductFAQ from '@components/ProductFAQ.astro';
import ProductCrossLinks from '@components/ProductCrossLinks.astro';
import LeadForm from '@components/LeadForm.tsx';
import { relatedSheetPiles } from '@lib/links';

export function getStaticPaths() {
  return getSheetPiles().map((p) => ({
    params: { slug: p.slug },
    props: { pile: p },
  }));
}

const { pile } = Astro.props;
const all = getSheetPiles();
const meta = shpuntMeta(pile.displayName, pile.weightPerMeterTons);
const related = relatedSheetPiles(all, pile.slug);

const weightKgPerM = pile.weightPerMeterTons * 1000;
---

<Gost
  title={meta.title}
  description={meta.description}
  h1={`Шпунт Ларсена ${pile.displayName}`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Шпунт Ларсена', href: '/shpunt/' },
    { label: pile.displayName, href: `/shpunt/${pile.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `SHPUNT-${pile.slug}`, weight: String((pile.weightPerMeterTons * 1000).toFixed(1)), gost: 'ГОСТ 4781-85', category: 'Шпунт Ларсена' }}
>
  <section class="mb-8">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{weightKgPerM.toFixed(1)}</div>
        <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{pile.weightPerMeterTons}</div>
        <div class="text-xs text-text-muted mt-1">Масса, т/м</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{pile.areaPerMeterM2}</div>
        <div class="text-xs text-text-muted mt-1">Площадь стены, м²/м</div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Характеристики</h2>
    <GostTable
      columns={[
        { key: 'param', label: 'Параметр' },
        { key: 'value', label: 'Значение', align: 'right' },
      ]}
      rows={[
        { param: 'Тип профиля', value: pile.type },
        { param: 'Масса 1 погонного метра', value: `${weightKgPerM.toFixed(1)} кг` },
        { param: 'Масса 1 погонного метра', value: `${pile.weightPerMeterTons} т` },
        { param: 'Площадь стены на 1 м', value: `${pile.areaPerMeterM2} м²` },
      ]}
    />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Расчёт массы по длине</h2>
    <WeightCalculator
      client:visible
      productName={`Шпунт ${pile.displayName}`}
      weightPerUnit={weightKgPerM}
      mode="length"
      unitLabel="кг/м"
      defaultLength={12}
    />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Область применения</h2>
    <p class="text-text-muted leading-relaxed">
      Шпунт Ларсена {pile.displayName} используется для устройства шпунтовых ограждений
      котлованов, укрепления берегов, строительства причалов и набережных,
      а также в качестве временных и постоянных подпорных стен.
      {weightKgPerM > 100 && ' Тяжёлый профиль — подходит для глубоких котлованов и высоких нагрузок.'}
      {weightKgPerM <= 100 && weightKgPerM > 60 && ' Средний профиль — универсальное решение для большинства задач ограждения.'}
      {weightKgPerM <= 60 && ' Лёгкий профиль — оптимален для неглубоких котлованов и временных ограждений.'}
    </p>
  </section>

  <ProductFAQ items={[
    { question: `Какой вес 1 метра шпунта ${pile.displayName}?`, answer: `Масса 1 погонного метра шпунта Ларсена ${pile.displayName} составляет <strong>${weightKgPerM.toFixed(1)} кг</strong> (${pile.weightPerMeterTons} т/м).` },
    { question: `Сколько метров шпунта ${pile.displayName} в тонне?`, answer: `В 1 тонне ${weightKgPerM > 0 ? (1000 / weightKgPerM).toFixed(2) : '—'} погонных метров шпунта ${pile.displayName}.` },
    { question: `Для чего применяется шпунт ${pile.displayName}?`, answer: `Шпунт Ларсена ${pile.displayName} применяется для устройства шпунтовых ограждений котлованов, укрепления берегов, строительства причалов, набережных и подпорных стен.` },
    { question: `Где купить шпунт ${pile.displayName}?`, answer: `Оставьте заявку — мы подберём лучшее предложение по шпунту ${pile.displayName}. <a href="/zayavka/" class="text-primary underline">Оставить заявку</a>.` },
  ]} />

  <section class="mb-8">
    <a href="#lead-form" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg scroll-smooth">
      Оставить заявку на шпунт {pile.displayName}
    </a>
  </section>

  <section class="mb-8">
    <a
      href={`/bu-metall/shpunt/${pile.slug}/`}
      class="flex items-center gap-4 p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all bg-surface"
    >
      <div class="flex-1">
        <div class="font-bold text-primary">{pile.displayName} б/у</div>
        <div class="text-sm text-text-muted mt-0.5">Вторичный шпунт — те же характеристики, экономия до 30–40%</div>
      </div>
      <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
    </a>
  </section>

  <ProductCrossLinks productSlug="shpunt" itemSlug={pile.slug} productType={`шпунта ${pile.displayName}`} basePath="/shpunt/" />

  <RelatedItems title="Другие типы шпунта" items={related} />

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Шпунт ${pile.displayName}`} />
  </section>
</Gost>
