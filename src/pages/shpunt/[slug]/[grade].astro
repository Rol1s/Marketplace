---
import Gost from '@layouts/Gost.astro';
import SteelGradeInfo from '@components/SteelGradeInfo.astro';
import LeadForm from '@components/LeadForm.tsx';
import { getSheetPiles, getSteelGradesForProduct } from '@lib/data';
import { SITE } from '@/config/site';

export function getStaticPaths() {
  const piles = getSheetPiles();
  const grades = getSteelGradesForProduct('shpunt');
  return piles.flatMap((p) =>
    grades.map((grade) => ({
      params: { slug: p.slug, grade: grade.slug },
      props: { pile: p, grade },
    }))
  );
}

const { pile, grade } = Astro.props;
const allGrades = getSteelGradesForProduct('shpunt');
const weightKgPerM = pile.weightPerMeterTons * 1000;
const productName = `шпунта ${pile.displayName}`;
const otherGrades = allGrades.map((g) => ({
  slug: g.slug,
  name: g.name,
  href: `/shpunt/${pile.slug}/${g.slug}/`,
}));
---

<Gost
  title={`Шпунт ${pile.displayName} из ${grade.name} — вес, характеристики | ${SITE.name}`}
  description={`Шпунт Ларсена ${pile.displayName} из ${grade.nameGen}. Масса ${weightKgPerM.toFixed(1)} кг/м. Свойства ${grade.name}.`}
  h1={`Шпунт Ларсена ${pile.displayName} из ${grade.name}`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Шпунт Ларсена', href: '/shpunt/' },
    { label: pile.displayName, href: `/shpunt/${pile.slug}/` },
    { label: grade.name, href: `/shpunt/${pile.slug}/${grade.slug}/` },
  ]}
>
  <SteelGradeInfo
    grade={grade}
    productName={productName}
    weightPerUnit={weightKgPerM}
    unitLabel="кг/м"
    otherGrades={otherGrades}
  />

  <section class="mb-8">
    <a href="#lead-form" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg scroll-smooth">
      Оставить заявку на шпунт {pile.displayName} из {grade.name}
    </a>
  </section>

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Шпунт ${pile.displayName} ${grade.name}`} />
  </section>
</Gost>
