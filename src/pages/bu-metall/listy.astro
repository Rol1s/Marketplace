---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import GostTable from '@components/GostTable.astro';
import LeadForm from '@components/LeadForm.tsx';
import { getSheets } from '@lib/data';
import { SITE } from '@/config/site';

const sheets = getSheets();

const title = `Листы стальные б/у — ${sheets.length} типоразмеров | ${SITE.name}`;
const description = `Б/у листы стальные по ГОСТ 19903-2015. ${sheets.length} типоразмеров. Характеристики, вес, применение.`;
---

<Base title={title} description={description}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs items={[
      { label: 'Справочник', href: '/sortament/' },
      { label: 'Б/у металлопрокат', href: '/bu-metall/' },
      { label: 'Листы б/у', href: '/bu-metall/listy/' },
    ]} />

    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-4">
      Листы стальные б/у — ГОСТ 19903-2015
    </h1>

    <p class="text-text-muted mb-8 max-w-3xl">
      Б/у листы стальные горячекатаные по ГОСТ 19903-2015. {sheets.length} типоразмеров.
      Характеристики и вес по ГОСТу.
    </p>

    <section class="mb-10">
      <GostTable
        columns={[
          { key: 'thickness', label: 'Толщина', unit: 'мм', align: 'right' },
          { key: 'width', label: 'Ширина', unit: 'мм', align: 'right' },
          { key: 'length', label: 'Длина', unit: 'мм', align: 'right' },
        ]}
        rows={sheets.map((s) => ({ ...s, _href: `/bu-metall/listy/${s.slug}/` }))}
      />
    </section>

    <LeadForm client:visible product="Листы б/у" />
  </div>
</Base>
