---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import GostTable from '@components/GostTable.astro';
import LeadForm from '@components/LeadForm.tsx';
import { getSheetPiles } from '@lib/data';
import { SITE } from '@/config/site';

const piles = getSheetPiles();

const title = `Шпунт Ларсена б/у — ${piles.length} типоразмеров | ${SITE.name}`;
const description = `Б/у шпунт Ларсена. ${piles.length} типоразмеров. Характеристики, вес п.м., применение.`;
---

<Base title={title} description={description}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs items={[
      { label: 'Справочник', href: '/sortament/' },
      { label: 'Б/у металлопрокат', href: '/bu-metall/' },
      { label: 'Шпунт б/у', href: '/bu-metall/shpunt/' },
    ]} />

    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-4">
      Шпунт Ларсена б/у
    </h1>

    <p class="text-text-muted mb-8 max-w-3xl">
      Б/у шпунт Ларсена — популярный материал для временных ограждений котлованов,
      берегоукреплений. {piles.length} типоразмеров. Технические характеристики аналогичны новому.
    </p>

    <section class="mb-10">
      <GostTable
        columns={[
          { key: 'displayName', label: 'Тип', align: 'left' },
          { key: 'weightPerMeterTons', label: 'Масса 1 м', unit: 'т', align: 'right' },
          { key: 'areaPerMeterM2', label: 'Площадь 1 м', unit: 'м²', align: 'right' },
        ]}
        rows={piles.map((p) => ({ ...p, _href: `/bu-metall/shpunt/${p.slug}/` }))}
      />
    </section>

    <LeadForm client:visible product="Шпунт Ларсена б/у" />
  </div>
</Base>
