---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { getProfileTubesSquare, getProfileTubesRect } from '@lib/data';
import { SITE } from '@/config/site';

const sq = getProfileTubesSquare();
const rect = getProfileTubesRect();
const title = `Профильная труба б/у — квадратная и прямоугольная | ${SITE.name}`;
const description = `Профильная труба б/у: ${sq.length} квадратных и ${rect.length} прямоугольных размеров. Вторичный прокат с экономией до 40%.`;
---

<Base title={title} description={description}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs items={[
      { label: 'Б/у металл', href: '/bu-metall/' },
      { label: 'Профильная труба б/у', href: '/bu-metall/profilnaya-truba/' },
    ]} />
    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-4">Профильная труба б/у</h1>
    <p class="text-text-muted mb-8">Каталог б/у профильных труб квадратного и прямоугольного сечения.</p>

    <h2 class="text-xl font-bold text-primary mb-3">Квадратная б/у</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 mb-8">
      {sq.slice(0, 20).map((t) => (
        <a href={`/bu-metall/profilnaya-truba/${t.slug}/`} class="group block p-3 rounded-lg border border-border hover:border-primary hover:shadow-md transition-all">
          <div class="text-lg font-bold text-primary group-hover:text-accent">{t.size}×{t.size}×{t.wallThickness}</div>
          <div class="text-xs text-text-muted mt-1">{t.weightPerMeter} кг/м</div>
        </a>
      ))}
    </div>

    <h2 class="text-xl font-bold text-primary mb-3">Прямоугольная б/у</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
      {rect.slice(0, 20).map((t) => (
        <a href={`/bu-metall/profilnaya-truba/${t.slug}/`} class="group block p-3 rounded-lg border border-border hover:border-primary hover:shadow-md transition-all">
          <div class="text-lg font-bold text-primary group-hover:text-accent">{t.sizeA}×{t.sizeB}×{t.wallThickness}</div>
          <div class="text-xs text-text-muted mt-1">{t.weightPerMeter} кг/м</div>
        </a>
      ))}
    </div>
  </div>
</Base>
