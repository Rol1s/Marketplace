---
import Gost from '@layouts/Gost.astro';
import BuMetallInfo from '@components/BuMetallInfo.astro';
import GostTable from '@components/GostTable.astro';
import LeadForm from '@components/LeadForm.tsx';
import ProductFAQ from '@components/ProductFAQ.astro';
import PipeCalculator from '@components/PipeCalculator';
import { getPipes, getPipesByDiameter } from '@lib/data';
import { SITE } from '@/config/site';

export function getStaticPaths() {
  return getPipes().map((pipe) => ({
    params: { slug: pipe.slug },
    props: { pipe },
  }));
}

const { pipe } = Astro.props;
const sameDiameter = getPipesByDiameter(pipe.diameter);

const weightRows = [1, 6, 11.7, 12].map((len) => ({
  length: len,
  weight: (pipe.weightPerMeter * len).toFixed(2),
  weightT: ((pipe.weightPerMeter * len) / 1000).toFixed(3),
}));
---

<Gost
  title={`Труба ${pipe.diameter}×${pipe.wallThickness} б/у — вес, характеристики | ${SITE.name}`}
  description={`Труба стальная б/у ${pipe.diameter}×${pipe.wallThickness} мм. Масса ${pipe.weightPerMeter} кг/м по ${pipe.gost}. Применение, характеристики.`}
  h1={`Труба ${pipe.diameter}×${pipe.wallThickness} б/у`}
  breadcrumbs={[
    { label: 'Справочник', href: '/sortament/' },
    { label: 'Б/у металлопрокат', href: '/bu-metall/' },
    { label: 'Трубы б/у', href: '/bu-metall/truby/' },
    { label: `${pipe.diameter}×${pipe.wallThickness}`, href: `/bu-metall/truby/${pipe.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `BU-PIPE-${pipe.diameter}x${pipe.wallThickness}`, weight: String(pipe.weightPerMeter), gost: pipe.gost, category: 'Трубы б/у' }}
>
  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Характеристики</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{pipe.diameter}</div>
        <div class="text-xs text-text-muted mt-1">Диаметр, мм</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{pipe.wallThickness}</div>
        <div class="text-xs text-text-muted mt-1">Стенка, мм</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{pipe.weightPerMeter}</div>
        <div class="text-xs text-text-muted mt-1">Масса 1 м, кг</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{(1000 / pipe.weightPerMeter).toFixed(1)}</div>
        <div class="text-xs text-text-muted mt-1">Метров в тонне</div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Масса по длине</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
      {weightRows.map((r) => (
        <div class="bg-surface rounded-lg p-3 text-center">
          <div class="text-xs text-text-muted">{r.length} м</div>
          <div class="text-sm font-bold text-primary">
            {Number(r.weightT) >= 1 ? `${r.weightT} т` : `${r.weight} кг`}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Калькулятор веса трубы б/у</h2>
    <PipeCalculator
      client:visible
      diameter={pipe.diameter}
      wallThickness={pipe.wallThickness}
      weightPerMeter={pipe.weightPerMeter}
      availableWalls={sameDiameter.map((p) => ({ wallThickness: p.wallThickness, weightPerMeter: p.weightPerMeter, slug: p.slug }))}
    />
  </section>

  <BuMetallInfo
    productName={`труба ${pipe.diameter}×${pipe.wallThickness} мм`}
    gost={pipe.gost}
    baseHref={`/truby/${pipe.slug}/`}
    baseLinkLabel={`Характеристики и калькулятор трубы ${pipe.diameter}×${pipe.wallThickness}`}
  />

  {sameDiameter.length > 1 && (
    <section class="mb-8">
      <h2 class="text-lg font-bold text-primary mb-3">Другие стенки для ⌀{pipe.diameter} мм</h2>
      <div class="flex flex-wrap gap-2">
        {sameDiameter.map((p) => (
          <a
            href={`/bu-metall/truby/${p.slug}/`}
            class={`inline-block px-3 py-2 rounded-lg text-sm border transition-colors ${
              p.slug === pipe.slug
                ? 'bg-primary text-white border-primary font-bold'
                : 'bg-surface border-border hover:border-primary text-text'
            }`}
          >
            {p.wallThickness} мм
          </a>
        ))}
      </div>
    </section>
  )}

  <ProductFAQ items={[
    {
      question: `Какой вес трубы ${pipe.diameter}×${pipe.wallThickness} б/у?`,
      answer: `Масса 1 погонного метра трубы б/у ${pipe.diameter}×${pipe.wallThickness} мм составляет <strong>${pipe.weightPerMeter} кг</strong> по ${pipe.gost}. Вес б/у трубы не отличается от нового проката.`,
    },
    {
      question: `Чем отличается труба б/у ${pipe.diameter}×${pipe.wallThickness} от новой?`,
      answer: `Б/у труба ${pipe.diameter}×${pipe.wallThickness} имеет те же геометрические характеристики и вес, что и новая. Отличия — в поверхности (следы эксплуатации) и в отсутствии завода-изготовителя. Перед продажей проходит контроль геометрии и толщины стенки.`,
    },
    {
      question: `Где применяется б/у труба ${pipe.diameter}×${pipe.wallThickness}?`,
      answer: `Б/у труба ${pipe.diameter}×${pipe.wallThickness} мм применяется в строительстве временных конструкций, заборов, сельхозобъектов, промышленных площадок, фундаментов и металлоконструкций, где не требуется новый сертифицированный прокат.`,
    },
  ]} />

  <section class="mb-8">
    <a
      href="#lead-form"
      class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg scroll-smooth"
    >
      Оставить заявку на трубу {pipe.diameter}×{pipe.wallThickness} б/у
    </a>
  </section>

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Труба ${pipe.diameter}×${pipe.wallThickness} б/у`} />
  </section>
</Gost>
