---
import Gost from '@layouts/Gost.astro';
import GostTable from '@components/GostTable.astro';
import BuMetallInfo from '@components/BuMetallInfo.astro';
import RelatedItems from '@components/RelatedItems.astro';
import ProductFAQ from '@components/ProductFAQ.astro';
import AddToCart from '@components/AddToCart.tsx';
import LeadForm from '@components/LeadForm.tsx';
import { getRebar } from '@lib/data';
import { SITE } from '@/config/site';
import { relatedRebar } from '@lib/links';

export function getStaticPaths() {
  return getRebar().map((r) => ({
    params: { slug: r.slug },
    props: { item: r },
  }));
}

const { item } = Astro.props;
const allItems = getRebar();
const related = relatedRebar(allItems, item.slug).map((l) => ({ ...l, href: l.href.replace('/armatura/', '/bu-metall/armatura/') }));
const title = `Арматура ⌀${item.diameter} мм б/у ${item.rebarClass} — характеристики, вес | ${SITE.name}`;
const description = `Арматура б/у ⌀${item.diameter} мм класс ${item.rebarClass}. Масса 1 м — ${item.weightPerMeter} кг. Характеристики вторичного арматурного проката.`;
---

<Gost
  title={title}
  description={description}
  h1={`Арматура ⌀${item.diameter} мм б/у — ${item.rebarClass}`}
  breadcrumbs={[
    { label: 'Б/у металл', href: '/bu-metall/' },
    { label: 'Арматура б/у', href: '/bu-metall/armatura/' },
    { label: `⌀${item.diameter}`, href: `/bu-metall/armatura/${item.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `BU-RB-${item.slug}`, weight: String(item.weightPerMeter), gost: 'ГОСТ 34028-2016', category: 'Арматура б/у' }}
>
  <section class="mb-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{item.diameter}</div>
        <div class="text-xs text-text-muted mt-1">Диаметр, мм</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{item.rebarClass}</div>
        <div class="text-xs text-text-muted mt-1">Класс</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{item.crossSectionArea}</div>
        <div class="text-xs text-text-muted mt-1">Площадь, см²</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{item.weightPerMeter}</div>
        <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
      </div>
    </div>
  </section>

  <BuMetallInfo />

  <section class="mb-8">
    <a href={`/armatura/${item.slug}/`} class="flex items-center gap-4 p-4 rounded-xl border-2 border-primary/30 hover:border-primary hover:shadow-md transition-all bg-surface">
      <div class="flex-1">
        <div class="font-bold text-primary">Арматура ⌀{item.diameter} новая</div>
        <div class="text-sm text-text-muted mt-0.5">Полные характеристики по ГОСТ 34028-2016</div>
      </div>
      <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
    </a>
  </section>

  <ProductFAQ items={[
    { question: `Можно ли использовать арматуру ${item.diameter} б/у?`, answer: `Да, б/у арматура ⌀${item.diameter} подходит для неответственных конструкций, заборов, временных сооружений. Экономия 30–40%.` },
    { question: `Какой вес арматуры ${item.diameter} мм б/у?`, answer: `Масса 1 м арматуры ⌀${item.diameter} — <strong>${item.weightPerMeter} кг</strong>, одинаково для новой и б/у.` },
  ]} />

  <RelatedItems title="Другие размеры б/у арматуры" items={related} />

  <section class="mb-8">
    <AddToCart client:visible id={item.slug} category="armatura" name={`Арматура ⌀${item.diameter} б/у`} gost="ГОСТ 34028-2016" weightPerMeter={item.weightPerMeter} />
  </section>

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Арматура ⌀${item.diameter} б/у`} />
  </section>
</Gost>
