---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import LeadForm from '@components/LeadForm';
import { SITE } from '@/config/site';

const title = `Оставить заявку на металлопрокат | ${SITE.name}`;
const description = 'Оставьте заявку на покупку или продажу металлопроката. Трубы, швеллеры, двутавры, листы, уголки, шпунт Ларсена. Быстрый ответ.';
---

<Base title={title} description={description}>
  <div class="max-w-2xl mx-auto px-4 py-12">
    <Breadcrumbs items={[
      { label: 'Заявка', href: '/zayavka/' },
    ]} />

    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-4">
      Оставить заявку на металлопрокат
    </h1>

    <p class="text-text-muted mb-8">
      Опишите что вам нужно — тип металла, размер, количество и город.
      Мы подберём предложения и свяжемся с вами.
    </p>

    <LeadForm client:visible source="zayavka-page" />

    <section class="mt-12">
      <h2 class="text-xl font-bold text-primary mb-4">Что мы можем найти</h2>
      <div class="grid grid-cols-2 gap-4">
        <div class="p-4 bg-surface rounded-lg">
          <div class="font-bold text-primary">Трубы</div>
          <div class="text-sm text-text-muted">Новые и б/у, все диаметры</div>
        </div>
        <div class="p-4 bg-surface rounded-lg">
          <div class="font-bold text-primary">Балки и швеллеры</div>
          <div class="text-sm text-text-muted">Двутавры, швеллеры, уголки</div>
        </div>
        <div class="p-4 bg-surface rounded-lg">
          <div class="font-bold text-primary">Листы</div>
          <div class="text-sm text-text-muted">Горячекатаные, все толщины</div>
        </div>
        <div class="p-4 bg-surface rounded-lg">
          <div class="font-bold text-primary">Шпунт Ларсена</div>
          <div class="text-sm text-text-muted">Новый и б/у, все типы</div>
        </div>
      </div>
    </section>
  </div>
</Base>
