---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import GostTable from '@components/GostTable.astro';
import { getStripSteel } from '@lib/data';
import { SITE } from '@/config/site';

const items = getStripSteel();
const title = `Полоса стальная горячекатаная ГОСТ 103-2006 — сортамент, вес | ${SITE.name}`;
const description = `Полный сортамент стальной полосы по ГОСТ 103-2006. ${items.length} типоразмеров. Таблица масс.`;
---

<Base title={title} description={description}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs items={[
      { label: 'Сортамент', href: '/sortament/' },
      { label: 'Полоса', href: '/polosa/' },
    ]} />
    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-4">Полоса стальная — ГОСТ 103-2006</h1>
    <p class="text-text-muted mb-8 max-w-3xl">{items.length} типоразмеров.</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 mb-10">
      {items.map((s) => (
        <a href={`/polosa/${s.slug}/`} class="group block p-3 rounded-lg border border-border hover:border-primary hover:shadow-md transition-all">
          <div class="text-lg font-bold text-primary group-hover:text-accent">{s.width}×{s.thickness}</div>
          <div class="text-xs text-text-muted mt-1">{s.weightPerMeter} кг/м</div>
        </a>
      ))}
    </div>
    <h2 class="text-xl font-bold text-primary mb-4">Таблица сортамента</h2>
    <GostTable
      columns={[
        { key: 'width', label: 'Ширина', unit: 'мм', align: 'right' },
        { key: 'thickness', label: 'Толщина', unit: 'мм', align: 'right' },
        { key: 'weightPerMeter', label: 'Масса 1 м', unit: 'кг', align: 'right' },
      ]}
      rows={items.map((s) => ({ ...s, _href: `/polosa/${s.slug}/` }))}
    />
  </div>
</Base>
