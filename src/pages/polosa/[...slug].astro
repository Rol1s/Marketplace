---
import Gost from '@layouts/Gost.astro';
import GostTable from '@components/GostTable.astro';
import RelatedItems from '@components/RelatedItems.astro';
import WeightCalculator from '@components/WeightCalculator';
import { getStripSteel } from '@lib/data';
import { stripSteelMeta } from '@lib/seo';
import { relatedStripSteel } from '@lib/links';
import ProductFAQ from '@components/ProductFAQ.astro';
import ProductCrossLinks from '@components/ProductCrossLinks.astro';
import LeadForm from '@components/LeadForm.tsx';

export function getStaticPaths() {
  return getStripSteel().map((s) => ({
    params: { slug: s.slug },
    props: { item: s },
  }));
}

const { item } = Astro.props;
const allItems = getStripSteel();
const meta = stripSteelMeta(item.width, item.thickness, item.weightPerMeter);
const related = relatedStripSteel(allItems, item.slug);
---

<Gost
  title={meta.title}
  description={meta.description}
  h1={`Полоса стальная ${item.width}×${item.thickness} мм — ГОСТ 103-2006`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Полоса', href: '/polosa/' },
    { label: `${item.width}×${item.thickness}`, href: `/polosa/${item.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `ST-${item.slug}`, weight: String(item.weightPerMeter), gost: 'ГОСТ 103-2006', category: 'Полоса стальная' }}
>
  <section class="mb-8">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{item.width}</div>
        <div class="text-xs text-text-muted mt-1">Ширина, мм</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{item.thickness}</div>
        <div class="text-xs text-text-muted mt-1">Толщина, мм</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{item.weightPerMeter}</div>
        <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Характеристики</h2>
    <GostTable
      columns={[{ key: 'param', label: 'Параметр' }, { key: 'value', label: 'Значение', align: 'right' }]}
      rows={[
        { param: 'Ширина', value: `${item.width} мм` },
        { param: 'Толщина', value: `${item.thickness} мм` },
        { param: 'Масса 1 м', value: `${item.weightPerMeter} кг` },
        { param: 'Метров в тонне', value: `${(1000 / item.weightPerMeter).toFixed(1)} м` },
        { param: 'ГОСТ', value: item.gost },
      ]}
    />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Расчёт массы</h2>
    <WeightCalculator client:visible productName={`Полоса ${item.width}×${item.thickness}`} weightPerUnit={item.weightPerMeter} mode="length" unitLabel="кг/м" defaultLength={6} />
  </section>

  <ProductFAQ items={[
    { question: `Какой вес полосы ${item.width}×${item.thickness}?`, answer: `Масса 1 м полосы ${item.width}×${item.thickness} по ГОСТ 103-2006 — <strong>${item.weightPerMeter} кг</strong>.` },
  ]} />

  <section class="mb-8">
    <a href="#lead-form" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg">
      Заявка на полосу {item.width}×{item.thickness}
    </a>
  </section>

  <ProductCrossLinks productSlug="polosa" itemSlug={item.slug} productType={`полосы ${item.width}×${item.thickness}`} basePath="/polosa/" />
  <RelatedItems title="Другие размеры полосы" items={related} />

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Полоса стальная ${item.width}×${item.thickness}`} />
  </section>
</Gost>
