---
import Gost from '@layouts/Gost.astro';
import SteelGradeInfo from '@components/SteelGradeInfo.astro';
import AddToCart from '@components/AddToCart.tsx';
import LeadForm from '@components/LeadForm.tsx';
import { getPipes, getSteelGradesForProduct } from '@lib/data';
import { SITE } from '@/config/site';

export function getStaticPaths() {
  const pipes = getPipes();
  const grades = getSteelGradesForProduct('truby');
  return pipes.flatMap((pipe) =>
    grades.map((grade) => ({
      params: { slug: pipe.slug, grade: grade.slug },
      props: { pipe, grade },
    }))
  );
}

const { pipe, grade } = Astro.props;
const allGrades = getSteelGradesForProduct('truby');
const productName = `трубы ${pipe.diameter}×${pipe.wallThickness}`;
const otherGrades = allGrades.map((g) => ({
  slug: g.slug,
  name: g.name,
  href: `/truby/${pipe.slug}/${g.slug}/`,
}));
---

<Gost
  title={`Труба ${pipe.diameter}×${pipe.wallThickness} из ${grade.name} — вес, характеристики | ${SITE.name}`}
  description={`Труба стальная ${pipe.diameter}×${pipe.wallThickness} мм из ${grade.nameGen}. Масса 1 м — ${pipe.weightPerMeter} кг. Свойства марки ${grade.name}, калькулятор веса.`}
  h1={`Труба ${pipe.diameter}×${pipe.wallThickness} из ${grade.name}`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Трубы', href: '/truby/' },
    { label: `${pipe.diameter}×${pipe.wallThickness}`, href: `/truby/${pipe.slug}/` },
    { label: grade.name, href: `/truby/${pipe.slug}/${grade.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `PIPE-${pipe.diameter}x${pipe.wallThickness}-${grade.slug}`, weight: String(pipe.weightPerMeter), gost: 'ГОСТ 10704-91', category: `Трубы из ${grade.name}` }}
>
  <SteelGradeInfo
    grade={grade}
    productName={productName}
    weightPerUnit={pipe.weightPerMeter}
    unitLabel="кг/м"
    otherGrades={otherGrades}
  />

  <section class="mb-8">
    <AddToCart client:visible id={`${pipe.slug}-${grade.slug}`} category="truby" name={`Труба ${pipe.diameter}×${pipe.wallThickness} ${grade.name}`} gost="ГОСТ 10704-91" weightPerMeter={pipe.weightPerMeter} />
  </section>

  <section class="mb-8">
    <a href="#lead-form" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg scroll-smooth">
      Оставить заявку на трубу {pipe.diameter}×{pipe.wallThickness} из {grade.name}
    </a>
  </section>

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Труба ${pipe.diameter}×${pipe.wallThickness} ${grade.name}`} />
  </section>
</Gost>
