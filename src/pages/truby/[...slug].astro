---
import Gost from '@layouts/Gost.astro';
import GostTable from '@components/GostTable.astro';
import RelatedItems from '@components/RelatedItems.astro';
import PipeCrossSection from '@components/PipeCrossSection.astro';
import PipeCalculator from '@components/PipeCalculator';
import { getPipes, getPipesByDiameter } from '@lib/data';
import { pipeMeta } from '@lib/seo';
import { pipeWeight, formatWeight } from '@lib/calculator';
import ProductFAQ from '@components/ProductFAQ.astro';
import { nearbyPipes } from '@lib/links';

export function getStaticPaths() {
  const pipes = getPipes();
  return pipes.map((pipe) => ({
    params: { slug: pipe.slug },
    props: { pipe },
  }));
}

const { pipe } = Astro.props;
const allPipes = getPipes();
const sameDiameter = getPipesByDiameter(pipe.diameter);
const meta = pipeMeta(pipe.diameter, pipe.wallThickness, pipe.weightPerMeter);

const weight1m = pipe.weightPerMeter;
const innerDiameter = pipe.diameter - 2 * pipe.wallThickness;

const nearby = nearbyPipes(allPipes, pipe.diameter);

const weightRows = [1, 2, 3, 6, 11.7, 12].map((len) => {
  const w = pipeWeight(pipe.diameter, pipe.wallThickness, len);
  return { length: len, weight: w.toFixed(2), weightT: (w / 1000).toFixed(3) };
});
---

<Gost
  title={meta.title}
  description={meta.description}
  h1={`Труба ${pipe.diameter}×${pipe.wallThickness} мм — ГОСТ 10704-91`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Трубы', href: '/truby/' },
    { label: `${pipe.diameter}×${pipe.wallThickness}`, href: `/truby/${pipe.slug}/` },
  ]}
>
  <!-- 1. Характеристики: SVG + 4 карточки -->
  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Характеристики</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
      <PipeCrossSection diameter={pipe.diameter} wallThickness={pipe.wallThickness} />
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-primary">{pipe.diameter}</div>
          <div class="text-xs text-text-muted mt-1">Диаметр, мм</div>
        </div>
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-primary">{pipe.wallThickness}</div>
          <div class="text-xs text-text-muted mt-1">Стенка, мм</div>
        </div>
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-accent">{weight1m}</div>
          <div class="text-xs text-text-muted mt-1">Масса 1 м, кг</div>
        </div>
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-primary">{innerDiameter.toFixed(1)}</div>
          <div class="text-xs text-text-muted mt-1">Внутр. ⌀, мм</div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Калькулятор + погрузка (интерактив) -->
  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Калькулятор веса и погрузки</h2>
    <PipeCalculator
      client:visible
      diameter={pipe.diameter}
      wallThickness={pipe.wallThickness}
      weightPerMeter={pipe.weightPerMeter}
    />
  </section>

  <ProductFAQ items={[
    { question: `Какой вес 1 метра трубы ${pipe.diameter}×${pipe.wallThickness}?`, answer: `Масса 1 погонного метра трубы стальной ${pipe.diameter}×${pipe.wallThickness} мм по ГОСТ 10704-91 составляет <strong>${weight1m} кг</strong>.` },
    { question: `Сколько труб ${pipe.diameter}×${pipe.wallThickness} в тонне?`, answer: `В 1 тонне ${weight1m > 0 ? (1000 / (weight1m * 11.7)).toFixed(0) : '—'} труб длиной 11.7 м (${weight1m > 0 ? (1000 / weight1m).toFixed(2) : '—'} погонных метров).` },
    { question: `Какой ГОСТ у трубы ${pipe.diameter}×${pipe.wallThickness}?`, answer: `Труба ${pipe.diameter}×${pipe.wallThickness} мм изготавливается по <strong>ГОСТ 10704-91</strong> (электросварные прямошовные). Сортамент труб регламентирует размеры и допуски.` },
    { question: `Где купить трубу ${pipe.diameter}×${pipe.wallThickness}?`, answer: `Оставьте заявку на нашем сайте — мы подберём лучшее предложение по трубе ${pipe.diameter}×${pipe.wallThickness} от проверенных поставщиков с доставкой по России. <a href="/zayavka/" class="text-primary underline">Оставить заявку</a>.` },
  ]} />

  <!-- 3. CTA -->
  <section class="mb-8">
    <a href="/zayavka/" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg">
      Оставить заявку на трубу {pipe.diameter}×{pipe.wallThickness}
    </a>
  </section>

  <!-- 4. Таблица веса — компактный grid вместо длинной таблицы -->
  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Масса трубы {pipe.diameter}×{pipe.wallThickness} по длине</h2>
    <div class="grid grid-cols-3 md:grid-cols-6 gap-2">
      {weightRows.map((r) => (
        <div class="bg-surface rounded-lg p-3 text-center">
          <div class="text-xs text-text-muted">{r.length} м</div>
          <div class="text-sm font-bold text-primary">{Number(r.weightT) >= 1 ? `${r.weightT} т` : `${r.weight} кг`}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- 5. Все стенки — компактно, со ссылками, сворачивается если >6 строк -->
  {sameDiameter.length > 1 && (
    <section class="mb-8">
      <h2 class="text-lg font-bold text-primary mb-3">
        Все стенки для ⌀{pipe.diameter} мм
      </h2>
      <div class="flex flex-wrap gap-2">
        {sameDiameter.slice(0, 8).map((p) => (
          <a
            href={`/truby/${p.slug}/`}
            class={`inline-block px-3 py-2 rounded-lg text-sm border transition-colors ${
              p.slug === pipe.slug
                ? 'bg-primary text-white border-primary font-bold'
                : 'bg-surface border-border hover:border-primary text-text'
            }`}
          >
            {p.wallThickness} мм — {p.weightPerMeter} кг/м
          </a>
        ))}
      </div>
      {sameDiameter.length > 8 && (
        <details class="mt-3">
          <summary class="text-sm text-primary cursor-pointer hover:underline">
            Ещё {sameDiameter.length - 8} вариантов
          </summary>
          <div class="flex flex-wrap gap-2 mt-2">
            {sameDiameter.slice(8).map((p) => (
              <a
                href={`/truby/${p.slug}/`}
                class={`inline-block px-3 py-2 rounded-lg text-sm border transition-colors ${
                  p.slug === pipe.slug
                    ? 'bg-primary text-white border-primary font-bold'
                    : 'bg-surface border-border hover:border-primary text-text'
                }`}
              >
                {p.wallThickness} мм — {p.weightPerMeter} кг/м
              </a>
            ))}
          </div>
        </details>
      )}
    </section>
  )}

  <!-- 6. Область применения -->
  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Область применения</h2>
    <div class="text-text-muted leading-relaxed space-y-2">
      <p>
        Труба стальная электросварная {pipe.diameter}×{pipe.wallThickness} мм (ГОСТ 10704-91) с массой погонного метра {weight1m} кг.
        {pipe.diameter <= 57 && ' Трубы малого диаметра применяются в системах водоснабжения, отопления, газоснабжения, при монтаже ограждений и каркасных конструкций. Также используются в качестве элементов мебели, перил и декоративных ограждений.'}
        {pipe.diameter > 57 && pipe.diameter <= 219 && ' Трубы среднего диаметра используются в строительстве, для прокладки инженерных коммуникаций, изготовления металлоконструкций и опор. Применяются в теплицах, навесах, каркасах зданий и сооружений.'}
        {pipe.diameter > 219 && pipe.diameter <= 530 && ' Трубы данного диаметра применяются в магистральных трубопроводах, строительстве мостов, свайных фундаментов. Востребованы в нефтегазовой промышленности и при устройстве буронабивных свай.'}
        {pipe.diameter > 530 && ' Трубы большого диаметра используются в магистральных нефте- и газопроводах, обсадных колоннах, при строительстве опор и свайных конструкций. Применяются в гидротехническом строительстве, промышленных дымовых трубах.'}
      </p>
      <p>
        Внутренний диаметр {innerDiameter.toFixed(1)} мм при стенке {pipe.wallThickness} мм обеспечивает
        {pipe.wallThickness / pipe.diameter < 0.05 ? ' высокую пропускную способность при умеренной массе.' : ' повышенную прочность и устойчивость к внешним нагрузкам.'}
      </p>
    </div>
  </section>

  <!-- 7. Перелинковка -->
  <RelatedItems title="Трубы других диаметров" items={nearby} />
</Gost>
