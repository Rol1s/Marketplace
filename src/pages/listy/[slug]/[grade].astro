---
import Gost from '@layouts/Gost.astro';
import SteelGradeInfo from '@components/SteelGradeInfo.astro';
import AddToCart from '@components/AddToCart.tsx';
import LeadForm from '@components/LeadForm.tsx';
import { getSheets, getSteelGradesForProduct } from '@lib/data';
import { sheetWeight } from '@lib/calculator';
import { SITE } from '@/config/site';

export function getStaticPaths() {
  const sheets = getSheets();
  const grades = getSteelGradesForProduct('listy');
  return sheets.flatMap((s) =>
    grades.map((grade) => ({
      params: { slug: s.slug, grade: grade.slug },
      props: { sheet: s, grade },
    }))
  );
}

const { sheet, grade } = Astro.props;
const allGrades = getSteelGradesForProduct('listy');
const weightKg = sheetWeight(sheet.thickness, sheet.width, sheet.length);
const productName = `листа ${sheet.thickness}×${sheet.width}×${sheet.length}`;
const otherGrades = allGrades.map((g) => ({
  slug: g.slug,
  name: g.name,
  href: `/listy/${sheet.slug}/${g.slug}/`,
}));
---

<Gost
  title={`Лист ${sheet.thickness}×${sheet.width}×${sheet.length} из ${grade.name} — вес | ${SITE.name}`}
  description={`Лист стальной ${sheet.thickness}×${sheet.width}×${sheet.length} мм из ${grade.nameGen}. Масса листа ${weightKg.toFixed(1)} кг. Свойства ${grade.name}.`}
  h1={`Лист ${sheet.thickness}×${sheet.width}×${sheet.length} из ${grade.name}`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Листы', href: '/listy/' },
    { label: `${sheet.thickness}×${sheet.width}×${sheet.length}`, href: `/listy/${sheet.slug}/` },
    { label: grade.name, href: `/listy/${sheet.slug}/${grade.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `CH-${sheet.slug}-${grade.slug}`, weight: String(weightKg), gost: 'ГОСТ 19903-2015', category: `Листы из ${grade.name}` }}
>
  <SteelGradeInfo
    grade={grade}
    productName={productName}
    weightPerUnit={weightKg}
    unitLabel="кг/лист"
    otherGrades={otherGrades}
  />

  <section class="mb-8">
    <AddToCart client:visible id={`${sheet.slug}-${grade.slug}`} category="listy" name={`Лист ${sheet.thickness}×${sheet.width}×${sheet.length} ${grade.name}`} gost="ГОСТ 19903-2015" weightPerMeter={weightKg} />
  </section>

  <section class="mb-8">
    <a href="#lead-form" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg scroll-smooth">
      Оставить заявку на лист {sheet.thickness}×{sheet.width}×{sheet.length} из {grade.name}
    </a>
  </section>

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Лист ${sheet.thickness}×${sheet.width}×${sheet.length} ${grade.name}`} />
  </section>
</Gost>
