---
import Gost from '@layouts/Gost.astro';
import RelatedItems from '@components/RelatedItems.astro';
import AngleCrossSection from '@components/AngleCrossSection.astro';
import WeightCalculator from '@components/WeightCalculator';
import { getAnglesUnequal } from '@lib/data';
import { angleUnequalMeta } from '@lib/seo';
import ProductFAQ from '@components/ProductFAQ.astro';
import ProductCrossLinks from '@components/ProductCrossLinks.astro';
import { relatedAngles } from '@lib/links';

export function getStaticPaths() {
  return getAnglesUnequal().map((a) => ({
    params: { slug: a.slug },
    props: { angle: a },
  }));
}

const { angle } = Astro.props;
const all = getAnglesUnequal();
const meta = angleUnequalMeta(angle.size, angle.massPerMeterKg);
const related = relatedAngles(all, angle.slug, '/ugolki/neravnopolochnye/');
---

<Gost
  title={meta.title}
  description={meta.description}
  h1={`Уголок неравнополочный ${angle.size} — ГОСТ 8510-86`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Уголки', href: '/ugolki/' },
    { label: 'Неравнополочные', href: '/ugolki/neravnopolochnye/' },
    { label: angle.size, href: `/ugolki/neravnopolochnye/${angle.slug}/` },
  ]}
>
  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Характеристики</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
      <AngleCrossSection a={angle.aMm} b={angle.bMm} t={angle.thicknessMm} isEqual={false} />
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-primary">{angle.aMm}x{angle.bMm}</div>
          <div class="text-xs text-text-muted mt-1">Полки, мм</div>
        </div>
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-primary">{angle.thicknessMm}</div>
          <div class="text-xs text-text-muted mt-1">Толщина, мм</div>
        </div>
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-primary">{angle.crossSectionAreaMm2}</div>
          <div class="text-xs text-text-muted mt-1">Площадь, мм²</div>
        </div>
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-accent">{angle.massPerMeterKg}</div>
          <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Расчёт массы по длине</h2>
    <WeightCalculator
      client:visible
      productName={`Уголок ${angle.size}`}
      weightPerUnit={angle.massPerMeterKg}
      mode="length"
      unitLabel="кг/м"
      defaultLength={6}
    />
  </section>

  <ProductFAQ items={[
    { question: `Какой вес 1 метра уголка ${angle.size}?`, answer: `Масса 1 погонного метра уголка неравнополочного ${angle.size} по ГОСТ 8510-86 составляет <strong>${angle.massPerMeterKg} кг</strong>.` },
    { question: `Сколько уголков ${angle.size} в тонне?`, answer: `В 1 тонне ${angle.massPerMeterKg > 0 ? (1000 / angle.massPerMeterKg).toFixed(2) : '—'} погонных метров уголка ${angle.size} (${angle.massPerMeterKg > 0 ? (1000 / (angle.massPerMeterKg * 6)).toFixed(0) : '—'} штук по 6 м).` },
    { question: `Какой ГОСТ у уголка ${angle.size}?`, answer: `Уголок неравнополочный ${angle.size} изготавливается по <strong>ГОСТ 8510-86</strong>. Стандарт определяет сортамент стальных горячекатаных неравнополочных уголков.` },
    { question: `Где купить уголок ${angle.size}?`, answer: `Оставьте заявку — мы подберём лучшее предложение по уголку ${angle.size}. <a href="/zayavka/" class="text-primary underline">Оставить заявку</a>.` },
  ]} />

  <section class="mb-8">
    <a href="/zayavka/" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg">
      Оставить заявку на уголок {angle.size}
    </a>
  </section>

  <ProductCrossLinks productSlug="ugolki" itemSlug={angle.slug} productType={`уголка ${angle.size}`} basePath="/ugolki/neravnopolochnye/" />

  <RelatedItems title="Другие размеры" items={related} />
</Gost>
