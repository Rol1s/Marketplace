---
import Gost from '@layouts/Gost.astro';
import SteelGradeInfo from '@components/SteelGradeInfo.astro';
import LeadForm from '@components/LeadForm.tsx';
import { getChannels, getSteelGradesForProduct } from '@lib/data';
import { SITE } from '@/config/site';

export function getStaticPaths() {
  const channels = getChannels();
  const grades = getSteelGradesForProduct('shvellery');
  return channels.flatMap((ch) =>
    grades.map((grade) => ({
      params: { slug: ch.slug, grade: grade.slug },
      props: { channel: ch, grade },
    }))
  );
}

const { channel, grade } = Astro.props;
const allGrades = getSteelGradesForProduct('shvellery');
const productName = `швеллера ${channel.profile}`;
const otherGrades = allGrades.map((g) => ({
  slug: g.slug,
  name: g.name,
  href: `/shvellery/${channel.slug}/${g.slug}/`,
}));
---

<Gost
  title={`Швеллер ${channel.profile} из ${grade.name} — вес, характеристики | ${SITE.name}`}
  description={`Швеллер ${channel.profile} из ${grade.nameGen}. Масса ${channel.weight} кг/м. Свойства ${grade.name}, расчёт массы.`}
  h1={`Швеллер ${channel.profile} из ${grade.name}`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Швеллеры', href: '/shvellery/' },
    { label: channel.profile, href: `/shvellery/${channel.slug}/` },
    { label: grade.name, href: `/shvellery/${channel.slug}/${grade.slug}/` },
  ]}
>
  <SteelGradeInfo
    grade={grade}
    productName={productName}
    weightPerUnit={channel.weight}
    unitLabel="кг/м"
    otherGrades={otherGrades}
  />

  <section class="mb-8">
    <a href="#lead-form" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg scroll-smooth">
      Оставить заявку на швеллер {channel.profile} из {grade.name}
    </a>
  </section>

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Швеллер ${channel.profile} ${grade.name}`} />
  </section>
</Gost>
