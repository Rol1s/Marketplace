---
import Gost from '@layouts/Gost.astro';
import GostTable from '@components/GostTable.astro';
import LeadForm from '@components/LeadForm.tsx';
import { SITE } from '@/config/site';
import comparisons from '@data/comparisons.json';

interface CompRow {
  param: string;
  valueA: string;
  valueB: string;
}

interface Comparison {
  slug: string;
  title: string;
  gostA: string;
  gostB: string;
  nameA: string;
  nameB: string;
  linkA: string;
  linkB: string;
  rows: CompRow[];
  recommendA: string;
  recommendB: string;
}

export function getStaticPaths() {
  return (comparisons as Comparison[]).map((c) => ({
    params: { slug: c.slug },
    props: { item: c },
  }));
}

const { item } = Astro.props as { item: Comparison };
const title = `${item.title} | ${SITE.name}`;
const description = `Сравнение ${item.gostA} и ${item.gostB}: ${item.nameA} vs ${item.nameB}. Таблица отличий, рекомендации по выбору.`;
---

<Gost
  title={title}
  description={description}
  h1={item.title}
  breadcrumbs={[
    { label: 'Сравнение ГОСТов', href: '/sravnenie/' },
    { label: `${item.gostA} vs ${item.gostB}`, href: `/sravnenie/${item.slug}/` },
  ]}
  schemaType="TechArticle"
>
  <section class="mb-8">
    <div class="grid grid-cols-2 gap-4">
      <a href={item.linkA} class="block p-4 rounded-xl border-2 border-primary/30 hover:border-primary transition-all bg-surface text-center">
        <div class="text-sm text-text-muted mb-1">{item.gostA}</div>
        <div class="font-bold text-primary">{item.nameA}</div>
      </a>
      <a href={item.linkB} class="block p-4 rounded-xl border-2 border-accent/30 hover:border-accent transition-all bg-surface text-center">
        <div class="text-sm text-text-muted mb-1">{item.gostB}</div>
        <div class="font-bold text-accent">{item.nameB}</div>
      </a>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Сравнительная таблица</h2>
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="bg-surface">
            <th class="p-3 text-left border border-border font-semibold text-primary">Параметр</th>
            <th class="p-3 text-left border border-border font-semibold text-primary">{item.gostA}</th>
            <th class="p-3 text-left border border-border font-semibold text-accent">{item.gostB}</th>
          </tr>
        </thead>
        <tbody>
          {item.rows.map((row) => (
            <tr>
              <td class="p-3 border border-border font-medium text-primary">{row.param}</td>
              <td class="p-3 border border-border text-text-muted">{row.valueA}</td>
              <td class="p-3 border border-border text-text-muted">{row.valueB}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Рекомендации по выбору</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-surface rounded-xl p-5">
        <div class="font-bold text-primary mb-2">Выбирайте {item.gostA}:</div>
        <p class="text-text-muted text-sm">{item.recommendA}</p>
      </div>
      <div class="bg-surface rounded-xl p-5">
        <div class="font-bold text-accent mb-2">Выбирайте {item.gostB}:</div>
        <p class="text-text-muted text-sm">{item.recommendB}</p>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Смотрите также</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a href={item.linkA} class="flex items-center gap-3 p-3 rounded-lg border border-border hover:border-primary hover:shadow-md transition-all">
        <span class="text-primary font-medium">{item.nameA} — сортамент</span>
        <svg class="w-4 h-4 text-primary ml-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href={item.linkB} class="flex items-center gap-3 p-3 rounded-lg border border-border hover:border-primary hover:shadow-md transition-all">
        <span class="text-primary font-medium">{item.nameB} — сортамент</span>
        <svg class="w-4 h-4 text-primary ml-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="/stati/" class="flex items-center gap-3 p-3 rounded-lg border border-border hover:border-primary hover:shadow-md transition-all">
        <span class="text-primary font-medium">Все статьи</span>
        <svg class="w-4 h-4 text-primary ml-auto" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Консультация: ${item.gostA} vs ${item.gostB}`} />
  </section>
</Gost>
