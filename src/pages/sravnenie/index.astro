---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { SITE } from '@/config/site';
import comparisons from '@data/comparisons.json';

const title = `Сравнение ГОСТов на металлопрокат | ${SITE.name}`;
const description = `${comparisons.length} таблиц сравнения ГОСТов: электросварные vs бесшовные трубы, швеллер vs двутавр, арматура старая vs новая.`;
---

<Base title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumbs items={[{ label: 'Сравнение ГОСТов', href: '/sravnenie/' }]} />
    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-4">Сравнение ГОСТов на металлопрокат</h1>
    <p class="text-text-muted mb-8">Таблицы «бок о бок» для выбора оптимального стандарта.</p>
    <div class="grid gap-4">
      {comparisons.map((c: any) => (
        <a href={`/sravnenie/${c.slug}/`} class="group block p-5 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all">
          <h2 class="text-lg font-bold text-primary group-hover:text-accent transition-colors mb-1">{c.title}</h2>
          <p class="text-sm text-text-muted">{c.gostA} vs {c.gostB}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
