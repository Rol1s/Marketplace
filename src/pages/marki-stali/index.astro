---
import Gost from '@layouts/Gost.astro';
import SectionIcon from '@components/SectionIcon.astro';
import { getSteelGrades } from '@lib/data';
import { SITE, SECTIONS } from '@/config/site';

const grades = getSteelGrades();
---

<Gost
  title={`Марки стали — справочник | ${SITE.name}`}
  description="Справочник марок стали для металлопроката. Ст3сп, Ст20, 09Г2С, 12Х18Н10Т и другие. Характеристики, применение, плотность."
  h1="Марки стали для металлопроката"
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Марки стали', href: '/marki-stali/' },
  ]}
>
  <p class="text-text-muted mb-8 leading-relaxed">
    Справочник основных марок стали, применяемых в производстве металлопроката.
    Для каждой марки указаны механические характеристики, плотность и совместимые виды продукции.
  </p>

  <div class="grid gap-6">
    {grades.map((grade) => (
      <a href={`/marki-stali/${grade.slug}/`}
         class="block bg-surface border border-border rounded-xl p-6 hover:border-primary transition-colors">
        <div class="flex items-start justify-between mb-3">
          <h2 class="text-xl font-bold text-primary">{grade.name}</h2>
          <span class="text-sm bg-primary/10 text-primary px-2 py-1 rounded">{grade.density} кг/м³</span>
        </div>
        <div class="grid grid-cols-3 gap-3 mb-4">
          <div class="text-center">
            <div class="text-sm font-bold text-accent">{grade.yieldStrength} МПа</div>
            <div class="text-xs text-text-muted">Текучесть</div>
          </div>
          <div class="text-center">
            <div class="text-sm font-bold text-primary">{grade.tensileStrength} МПа</div>
            <div class="text-xs text-text-muted">Прочность</div>
          </div>
          <div class="text-center">
            <div class="text-sm font-bold text-primary">{grade.elongation}%</div>
            <div class="text-xs text-text-muted">Удлинение</div>
          </div>
        </div>
        <p class="text-sm text-text-muted line-clamp-2">{grade.description}</p>
        <div class="flex flex-wrap gap-2 mt-3">
          {SECTIONS.filter((s) => grade.products.includes(s.slug)).map((s) => (
            <span class="inline-flex items-center gap-1 text-xs bg-white border border-border rounded px-2 py-1">
              <SectionIcon slug={s.slug} class="w-3 h-3" />
              {s.name}
            </span>
          ))}
        </div>
      </a>
    ))}
  </div>
</Gost>
