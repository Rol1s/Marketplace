---
import Gost from '@layouts/Gost.astro';
import GostTable from '@components/GostTable.astro';
import RelatedItems from '@components/RelatedItems.astro';
import WeightCalculator from '@components/WeightCalculator';
import { getRoundBars } from '@lib/data';
import { roundBarMeta } from '@lib/seo';
import { relatedRoundBars } from '@lib/links';
import ProductFAQ from '@components/ProductFAQ.astro';
import ProductCrossLinks from '@components/ProductCrossLinks.astro';
import LeadForm from '@components/LeadForm.tsx';

export function getStaticPaths() {
  return getRoundBars().map((r) => ({
    params: { slug: r.slug },
    props: { item: r },
  }));
}

const { item } = Astro.props;
const allItems = getRoundBars();
const meta = roundBarMeta(item.diameter, item.weightPerMeter);
const related = relatedRoundBars(allItems, item.slug);
---

<Gost
  title={meta.title}
  description={meta.description}
  h1={`Круг стальной ⌀${item.diameter} мм — ГОСТ 2590-2006`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Круг', href: '/krug/' },
    { label: `⌀${item.diameter}`, href: `/krug/${item.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `RB-${item.slug}`, weight: String(item.weightPerMeter), gost: 'ГОСТ 2590-2006', category: 'Круг стальной' }}
>
  <section class="mb-8">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{item.diameter}</div>
        <div class="text-xs text-text-muted mt-1">Диаметр, мм</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{item.crossSectionArea}</div>
        <div class="text-xs text-text-muted mt-1">Площадь, см²</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{item.weightPerMeter}</div>
        <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Характеристики</h2>
    <GostTable
      columns={[{ key: 'param', label: 'Параметр' }, { key: 'value', label: 'Значение', align: 'right' }]}
      rows={[
        { param: 'Диаметр', value: `${item.diameter} мм` },
        { param: 'Площадь сечения', value: `${item.crossSectionArea} см²` },
        { param: 'Масса 1 м', value: `${item.weightPerMeter} кг` },
        { param: 'Метров в тонне', value: `${(1000 / item.weightPerMeter).toFixed(1)} м` },
        { param: 'ГОСТ', value: item.gost },
      ]}
    />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Расчёт массы</h2>
    <WeightCalculator client:visible productName={`Круг ⌀${item.diameter}`} weightPerUnit={item.weightPerMeter} mode="length" unitLabel="кг/м" defaultLength={6} />
  </section>

  <ProductFAQ items={[
    { question: `Какой вес круга ⌀${item.diameter} мм?`, answer: `Масса 1 м круга ⌀${item.diameter} по ГОСТ 2590-2006 — <strong>${item.weightPerMeter} кг</strong>.` },
    { question: `Формула расчёта веса круга?`, answer: `Вес (кг/м) = π/4 × d² × 7,85 / 1000, где d — диаметр в мм.` },
  ]} />

  <section class="mb-8">
    <a href="#lead-form" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg">
      Заявка на круг ⌀{item.diameter}
    </a>
  </section>

  <ProductCrossLinks productSlug="krug" itemSlug={item.slug} productType={`круга ⌀${item.diameter}`} basePath="/krug/" />
  <RelatedItems title="Другие диаметры круга" items={related} />

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Круг стальной ⌀${item.diameter}`} />
  </section>
</Gost>
