---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import GostTable from '@components/GostTable.astro';
import { getRoundBars } from '@lib/data';
import { SITE } from '@/config/site';

const items = getRoundBars();
const title = `Круг стальной горячекатаный ГОСТ 2590-2006 — сортамент, вес | ${SITE.name}`;
const description = `Полный сортамент стального круга по ГОСТ 2590-2006. ${items.length} диаметров от ${items[0].diameter} до ${items[items.length - 1].diameter} мм. Таблица масс.`;
---

<Base title={title} description={description}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs items={[
      { label: 'Сортамент', href: '/sortament/' },
      { label: 'Круг', href: '/krug/' },
    ]} />
    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-4">Круг стальной горячекатаный — ГОСТ 2590-2006</h1>
    <p class="text-text-muted mb-8 max-w-3xl">{items.length} диаметров от {items[0].diameter} до {items[items.length - 1].diameter} мм.</p>
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-2 mb-10">
      {items.map((r) => (
        <a href={`/krug/${r.slug}/`} class="group block p-2 rounded-lg border border-border hover:border-primary hover:shadow-md transition-all text-center">
          <div class="text-lg font-bold text-primary group-hover:text-accent">⌀{r.diameter}</div>
          <div class="text-xs text-text-muted">{r.weightPerMeter} кг/м</div>
        </a>
      ))}
    </div>
    <h2 class="text-xl font-bold text-primary mb-4">Таблица сортамента</h2>
    <GostTable
      columns={[
        { key: 'diameter', label: 'Диаметр', unit: 'мм', align: 'right' },
        { key: 'crossSectionArea', label: 'Площадь', unit: 'см²', align: 'right' },
        { key: 'weightPerMeter', label: 'Масса 1 м', unit: 'кг', align: 'right' },
      ]}
      rows={items.map((r) => ({ ...r, _href: `/krug/${r.slug}/` }))}
    />
  </div>
</Base>
