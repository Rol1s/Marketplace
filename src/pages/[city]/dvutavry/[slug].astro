---
import Gost from '@layouts/Gost.astro';
import WeightCalculator from '@components/WeightCalculator';
import ProductFAQ from '@components/ProductFAQ.astro';
import AddToCart from '@components/AddToCart.tsx';
import LeadForm from '@components/LeadForm.tsx';
import { getCities, getBeams } from '@lib/data';
import { SITE } from '@/config/site';
import type { City, Beam } from '@lib/types';

export function getStaticPaths() {
  const cities = getCities();
  const beams = getBeams();
  return cities.flatMap((city) =>
    beams.map((beam) => ({
      params: { city: city.slug, slug: beam.slug },
      props: { city, beam },
    }))
  );
}

const { city, beam } = Astro.props as { city: City; beam: Beam };
---

<Gost
  title={`Двутавр ${beam.profile} ${city.namePrep} — цена, доставка | ${SITE.name}`}
  description={`Купить двутавр ${beam.profile} ${city.namePrep}. Масса ${beam.weightPerMeter} кг/м. Доставка по ${city.region}.`}
  h1={`Двутавр ${beam.profile} ${city.namePrep}`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: city.name, href: `/${city.slug}/` },
    { label: 'Двутавры', href: `/dvutavry/` },
    { label: beam.profile, href: `/${city.slug}/dvutavry/${beam.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `BEAM-${beam.slug}`, weight: String(beam.weightPerMeter), gost: 'ГОСТ 35087-2024', category: 'Двутавры' }}
>
  <section class="mb-8">
    <div class="grid grid-cols-3 gap-3">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{beam.profile}</div>
        <div class="text-xs text-text-muted mt-1">Профиль</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{beam.weightPerMeter}</div>
        <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{beam.h}</div>
        <div class="text-xs text-text-muted mt-1">Высота h, мм</div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Калькулятор веса</h2>
    <WeightCalculator client:visible productName={`Двутавр ${beam.profile}`} weightPerUnit={beam.weightPerMeter} mode="length" unitLabel="кг/м" />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Доставка {city.namePrep}</h2>
    <p class="text-text-muted leading-relaxed">
      Двутавр {beam.profile} по ГОСТ 35087-2024 с доставкой {city.namePrep} и по {city.region}.
      <a href={`/dvutavry/${beam.slug}/`} class="text-primary underline ml-1">Подробные характеристики →</a>
    </p>
  </section>

  <a href={`/bu-metall/dvutavry/${beam.slug}/`}
     class="flex items-center gap-3 p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all bg-surface mb-8">
    <div class="flex-1">
      <div class="font-bold text-primary text-sm">Двутавр {beam.profile} б/у</div>
      <div class="text-xs text-text-muted mt-0.5">Вторичный прокат — экономия до 40%</div>
    </div>
    <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
  </a>

  <ProductFAQ items={[
    { question: `Где купить двутавр ${beam.profile} ${city.namePrep}?`, answer: `Оставьте заявку — подберём двутавр ${beam.profile} от поставщиков ${city.namePrep}.` },
    { question: `Какой вес двутавра ${beam.profile}?`, answer: `Масса 1 м — <strong>${beam.weightPerMeter} кг</strong> по ГОСТ 35087-2024.` },
    { question: `Есть ли доставка ${city.namePrep}?`, answer: `Да, доставка по ${city.region}.` },
  ]} />

  <section class="mb-8">
    <AddToCart client:visible id={beam.slug} category="dvutavry" name={`Двутавр ${beam.profile} ${city.namePrep}`} gost="ГОСТ 35087-2024" weightPerMeter={beam.weightPerMeter} />
  </section>

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Двутавр ${beam.profile} ${city.namePrep}`} />
  </section>
</Gost>
