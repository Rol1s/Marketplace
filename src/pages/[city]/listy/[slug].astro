---
import Gost from '@layouts/Gost.astro';
import WeightCalculator from '@components/WeightCalculator';
import ProductFAQ from '@components/ProductFAQ.astro';
import LeadForm from '@components/LeadForm.tsx';
import { getCities, getSheets } from '@lib/data';
import { sheetWeight } from '@lib/calculator';
import { SITE } from '@/config/site';
import type { City, Sheet } from '@lib/types';

export function getStaticPaths() {
  const cities = getCities();
  const sheets = getSheets();
  return cities.flatMap((city) =>
    sheets.map((sheet) => ({
      params: { city: city.slug, slug: sheet.slug },
      props: { city, sheet },
    }))
  );
}

const { city, sheet } = Astro.props as { city: City; sheet: Sheet };
const weightKg = sheetWeight(sheet.thickness, sheet.width, sheet.length);
---

<Gost
  title={`Лист ${sheet.thickness}×${sheet.width}×${sheet.length} ${city.namePrep} — цена | ${SITE.name}`}
  description={`Купить лист стальной ${sheet.thickness}×${sheet.width}×${sheet.length} мм ${city.namePrep}. Масса ${weightKg.toFixed(1)} кг. Доставка по ${city.region}.`}
  h1={`Лист ${sheet.thickness}×${sheet.width}×${sheet.length} ${city.namePrep}`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: city.name, href: `/${city.slug}/` },
    { label: 'Листы', href: `/listy/` },
    { label: `${sheet.thickness}×${sheet.width}×${sheet.length}`, href: `/${city.slug}/listy/${sheet.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `SHEET-${sheet.slug}`, weight: String(weightKg.toFixed(2)), gost: 'ГОСТ 19903-2015', category: 'Листы стальные' }}
>
  <section class="mb-8">
    <div class="grid grid-cols-3 gap-3">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{sheet.thickness}</div>
        <div class="text-xs text-text-muted mt-1">Толщина, мм</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{sheet.width}×{sheet.length}</div>
        <div class="text-xs text-text-muted mt-1">Размеры, мм</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{weightKg.toFixed(1)}</div>
        <div class="text-xs text-text-muted mt-1">Масса, кг</div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Калькулятор веса</h2>
    <WeightCalculator client:visible productName={`Лист ${sheet.thickness}×${sheet.width}×${sheet.length}`} weightPerUnit={weightKg} mode="piece" unitLabel="кг/лист" />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Доставка {city.namePrep}</h2>
    <p class="text-text-muted leading-relaxed">
      Лист {sheet.thickness}×{sheet.width}×{sheet.length} мм с доставкой {city.namePrep} и по {city.region}.
      <a href={`/listy/${sheet.slug}/`} class="text-primary underline ml-1">Подробные характеристики →</a>
    </p>
  </section>

  <a href={`/bu-metall/listy/${sheet.slug}/`}
     class="flex items-center gap-3 p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all bg-surface mb-8">
    <div class="flex-1">
      <div class="font-bold text-primary text-sm">Лист {sheet.thickness}×{sheet.width}×{sheet.length} б/у</div>
      <div class="text-xs text-text-muted mt-0.5">Вторичный прокат — экономия до 40%</div>
    </div>
    <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
  </a>

  <ProductFAQ items={[
    { question: `Где купить лист ${sheet.thickness} мм ${city.namePrep}?`, answer: `Оставьте заявку — подберём лист ${sheet.thickness}×${sheet.width}×${sheet.length} ${city.namePrep}.` },
    { question: `Какой вес листа ${sheet.thickness}×${sheet.width}×${sheet.length}?`, answer: `Масса листа — <strong>${weightKg.toFixed(1)} кг</strong>.` },
    { question: `Есть ли доставка ${city.namePrep}?`, answer: `Да, доставка по ${city.region}.` },
  ]} />

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Лист ${sheet.thickness}×${sheet.width}×${sheet.length} ${city.namePrep}`} />
  </section>
</Gost>
