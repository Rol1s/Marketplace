---
import Gost from '@layouts/Gost.astro';
import WeightCalculator from '@components/WeightCalculator';
import ProductFAQ from '@components/ProductFAQ.astro';
import LeadForm from '@components/LeadForm.tsx';
import { getCities, getChannels } from '@lib/data';
import { SITE } from '@/config/site';
import type { City, Channel } from '@lib/types';

export function getStaticPaths() {
  const cities = getCities();
  const channels = getChannels();
  return cities.flatMap((city) =>
    channels.map((ch) => ({
      params: { city: city.slug, slug: ch.slug },
      props: { city, channel: ch },
    }))
  );
}

const { city, channel } = Astro.props as { city: City; channel: Channel };
---

<Gost
  title={`Швеллер ${channel.profile} ${city.namePrep} — цена, доставка | ${SITE.name}`}
  description={`Купить швеллер ${channel.profile} ${city.namePrep}. Масса ${channel.weight} кг/м. Доставка по ${city.region}.`}
  h1={`Швеллер ${channel.profile} ${city.namePrep}`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: city.name, href: `/${city.slug}/` },
    { label: 'Швеллеры', href: `/shvellery/` },
    { label: channel.profile, href: `/${city.slug}/shvellery/${channel.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `CH-${channel.slug}`, weight: String(channel.weight), gost: 'ГОСТ 8240-97', category: 'Швеллеры' }}
>
  <section class="mb-8">
    <div class="grid grid-cols-3 gap-3">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{channel.profile}</div>
        <div class="text-xs text-text-muted mt-1">Профиль</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{channel.weight}</div>
        <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{channel.h}×{channel.b}</div>
        <div class="text-xs text-text-muted mt-1">h×b, мм</div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Калькулятор веса</h2>
    <WeightCalculator client:visible productName={`Швеллер ${channel.profile}`} weightPerUnit={channel.weight} mode="length" unitLabel="кг/м" />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Доставка {city.namePrep}</h2>
    <p class="text-text-muted leading-relaxed">
      Швеллер {channel.profile} по ГОСТ 8240-97 с доставкой {city.namePrep} и по {city.region}.
      <a href={`/shvellery/${channel.slug}/`} class="text-primary underline ml-1">Подробные характеристики →</a>
    </p>
  </section>

  <a href={`/bu-metall/shvellery/${channel.slug}/`}
     class="flex items-center gap-3 p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all bg-surface mb-8">
    <div class="flex-1">
      <div class="font-bold text-primary text-sm">Швеллер {channel.profile} б/у</div>
      <div class="text-xs text-text-muted mt-0.5">Вторичный прокат — экономия до 40%</div>
    </div>
    <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
  </a>

  <ProductFAQ items={[
    { question: `Где купить швеллер ${channel.profile} ${city.namePrep}?`, answer: `Оставьте заявку — подберём швеллер ${channel.profile} от поставщиков ${city.namePrep}.` },
    { question: `Какой вес швеллера ${channel.profile}?`, answer: `Масса 1 м — <strong>${channel.weight} кг</strong> по ГОСТ 8240-97.` },
    { question: `Есть ли доставка ${city.namePrep}?`, answer: `Да, доставка по ${city.region}.` },
  ]} />

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Швеллер ${channel.profile} ${city.namePrep}`} />
  </section>
</Gost>
