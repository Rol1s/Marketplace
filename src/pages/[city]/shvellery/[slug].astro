---
import Gost from '@layouts/Gost.astro';
import ProductFAQ from '@components/ProductFAQ.astro';
import { getCities, getChannels } from '@lib/data';
import { SITE } from '@/config/site';
import type { City, Channel } from '@lib/types';

export function getStaticPaths() {
  const cities = getCities();
  const channels = getChannels();
  return cities.flatMap((city) =>
    channels.map((ch) => ({
      params: { city: city.slug, slug: ch.slug },
      props: { city, channel: ch },
    }))
  );
}

const { city, channel } = Astro.props as { city: City; channel: Channel };
---

<Gost
  title={`Швеллер ${channel.profile} ${city.namePrep} — цена, доставка | ${SITE.name}`}
  description={`Купить швеллер ${channel.profile} ${city.namePrep}. Масса ${channel.weight} кг/м. Наличие, цены, доставка по ${city.region}.`}
  h1={`Швеллер ${channel.profile} ${city.namePrep}`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: city.name, href: `/${city.slug}/` },
    { label: 'Швеллеры', href: `/shvellery/` },
    { label: channel.profile, href: `/${city.slug}/shvellery/${channel.slug}/` },
  ]}
>
  <section class="mb-8">
    <div class="grid grid-cols-3 gap-3">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{channel.profile}</div>
        <div class="text-xs text-text-muted mt-1">Профиль</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{channel.weight}</div>
        <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{channel.h}×{channel.b}</div>
        <div class="text-xs text-text-muted mt-1">h×b, мм</div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Доставка {city.namePrep}</h2>
    <p class="text-text-muted leading-relaxed">
      Швеллер {channel.profile} по ГОСТ 8240-97 доступен с доставкой {city.namePrep} и по {city.region}.
      <a href={`/shvellery/${channel.slug}/`} class="text-primary underline">Подробные характеристики швеллера {channel.profile}</a>.
    </p>
  </section>

  <ProductFAQ items={[
    { question: `Где купить швеллер ${channel.profile} ${city.namePrep}?`, answer: `Оставьте заявку — мы подберём швеллер ${channel.profile} от поставщиков ${city.namePrep}. <a href="/zayavka/" class="text-primary underline">Оставить заявку</a>.` },
    { question: `Какой вес швеллера ${channel.profile}?`, answer: `Масса 1 м швеллера ${channel.profile} — <strong>${channel.weight} кг</strong>.` },
    { question: `Есть ли доставка ${city.namePrep}?`, answer: `Да, доставка металлопроката ${city.namePrep} и по ${city.region}.` },
  ]} />

  <section class="mb-8">
    <a href="/zayavka/" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg">
      Купить швеллер {channel.profile} {city.namePrep}
    </a>
  </section>
</Gost>
