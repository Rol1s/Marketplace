---
import Gost from '@layouts/Gost.astro';
import WeightCalculator from '@components/WeightCalculator';
import ProductFAQ from '@components/ProductFAQ.astro';
import LeadForm from '@components/LeadForm.tsx';
import { getCities, getAnglesEqual, getAnglesUnequal } from '@lib/data';
import { SITE } from '@/config/site';
import type { City, AngleEqual } from '@lib/types';

export function getStaticPaths() {
  const cities = getCities();
  const angles = [...getAnglesEqual(), ...getAnglesUnequal()];
  return cities.flatMap((city) =>
    angles.map((angle) => ({
      params: { city: city.slug, slug: angle.slug },
      props: { city, angle },
    }))
  );
}

const { city, angle } = Astro.props as { city: City; angle: AngleEqual };
---

<Gost
  title={`Уголок ${angle.size} ${city.namePrep} — цена, доставка | ${SITE.name}`}
  description={`Купить уголок ${angle.size} ${city.namePrep}. Масса ${angle.massPerMeterKg} кг/м. Доставка по ${city.region}.`}
  h1={`Уголок ${angle.size} ${city.namePrep}`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: city.name, href: `/${city.slug}/` },
    { label: 'Уголки', href: `/ugolki/` },
    { label: angle.size, href: `/${city.slug}/ugolki/${angle.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `ANGLE-${angle.slug}`, weight: String(angle.massPerMeterKg), gost: angle.gost, category: 'Уголки' }}
>
  <section class="mb-8">
    <div class="grid grid-cols-3 gap-3">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{angle.size}</div>
        <div class="text-xs text-text-muted mt-1">Размер</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{angle.massPerMeterKg}</div>
        <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{angle.thicknessMm}</div>
        <div class="text-xs text-text-muted mt-1">Толщина, мм</div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Калькулятор веса</h2>
    <WeightCalculator client:visible productName={`Уголок ${angle.size}`} weightPerUnit={angle.massPerMeterKg} mode="length" unitLabel="кг/м" />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Доставка {city.namePrep}</h2>
    <p class="text-text-muted leading-relaxed">
      Уголок {angle.size} по {angle.gost} с доставкой {city.namePrep} и по {city.region}.
      <a href={`/ugolki/ravnopolochnye/${angle.slug}/`} class="text-primary underline ml-1">Подробные характеристики →</a>
    </p>
  </section>

  <a href={`/bu-metall/ugolki/${angle.slug}/`}
     class="flex items-center gap-3 p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all bg-surface mb-8">
    <div class="flex-1">
      <div class="font-bold text-primary text-sm">Уголок {angle.size} б/у</div>
      <div class="text-xs text-text-muted mt-0.5">Вторичный прокат — экономия до 40%</div>
    </div>
    <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
  </a>

  <ProductFAQ items={[
    { question: `Где купить уголок ${angle.size} ${city.namePrep}?`, answer: `Оставьте заявку — подберём уголок ${angle.size} ${city.namePrep}.` },
    { question: `Какой вес уголка ${angle.size}?`, answer: `Масса 1 м — <strong>${angle.massPerMeterKg} кг</strong>.` },
    { question: `Есть ли доставка ${city.namePrep}?`, answer: `Да, доставка по ${city.region}.` },
  ]} />

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Уголок ${angle.size} ${city.namePrep}`} />
  </section>
</Gost>
