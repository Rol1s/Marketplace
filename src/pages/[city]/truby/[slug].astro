---
import Gost from '@layouts/Gost.astro';
import PipeCalculator from '@components/PipeCalculator';
import ProductFAQ from '@components/ProductFAQ.astro';
import LeadForm from '@components/LeadForm.tsx';
import { getCities, getPipes, getPipesByDiameter } from '@lib/data';
import { SITE } from '@/config/site';
import type { City, Pipe } from '@lib/types';

export function getStaticPaths() {
  const cities = getCities();
  const pipes = getPipes().filter((p) => p.diameter >= 219 && p.diameter <= 1420);
  return cities.flatMap((city) =>
    pipes.map((pipe) => ({
      params: { city: city.slug, slug: pipe.slug },
      props: { city, pipe },
    }))
  );
}

const { city, pipe } = Astro.props as { city: City; pipe: Pipe };
const sameDiameter = getPipesByDiameter(pipe.diameter);
---

<Gost
  title={`Труба ${pipe.diameter}×${pipe.wallThickness} ${city.namePrep} — цена, доставка | ${SITE.name}`}
  description={`Купить трубу стальную ${pipe.diameter}×${pipe.wallThickness} мм ${city.namePrep}. Масса ${pipe.weightPerMeter} кг/м. Доставка по ${city.region}.`}
  h1={`Труба ${pipe.diameter}×${pipe.wallThickness} ${city.namePrep}`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: city.name, href: `/${city.slug}/` },
    { label: 'Трубы', href: `/truby/` },
    { label: `${pipe.diameter}×${pipe.wallThickness}`, href: `/${city.slug}/truby/${pipe.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `PIPE-${pipe.diameter}x${pipe.wallThickness}`, weight: String(pipe.weightPerMeter), gost: 'ГОСТ 10704-91', category: 'Трубы стальные' }}
>
  <section class="mb-8">
    <div class="grid grid-cols-3 gap-3">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{pipe.diameter}×{pipe.wallThickness}</div>
        <div class="text-xs text-text-muted mt-1">Размер, мм</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{pipe.weightPerMeter}</div>
        <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{pipe.weightPerMeter > 0 ? (1000 / pipe.weightPerMeter).toFixed(1) : '—'}</div>
        <div class="text-xs text-text-muted mt-1">Метров в тонне</div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Калькулятор веса</h2>
    <PipeCalculator
      client:visible
      diameter={pipe.diameter}
      wallThickness={pipe.wallThickness}
      weightPerMeter={pipe.weightPerMeter}
      availableWalls={sameDiameter.map((p) => ({ wallThickness: p.wallThickness, weightPerMeter: p.weightPerMeter, slug: p.slug }))}
    />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Доставка {city.namePrep}</h2>
    <p class="text-text-muted leading-relaxed">
      Труба {pipe.diameter}×{pipe.wallThickness} мм доступна с доставкой {city.namePrep} и по {city.region}.
      <a href={`/truby/${pipe.slug}/`} class="text-primary underline ml-1">Подробные характеристики →</a>
    </p>
  </section>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
    <a href={`/${city.slug}/bu-metall/truby/${pipe.slug}/`}
       class="flex items-center gap-3 p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all bg-surface">
      <div class="flex-1">
        <div class="font-bold text-primary text-sm">Труба {pipe.diameter}×{pipe.wallThickness} б/у {city.namePrep}</div>
        <div class="text-xs text-text-muted mt-0.5">Вторичный прокат — экономия до 40%</div>
      </div>
      <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
    </a>
    <a href={`/${city.slug}/truby/${pipe.slug}/vus/`}
       class="flex items-center gap-3 p-4 rounded-xl border border-primary/30 hover:border-primary hover:shadow-md transition-all bg-surface">
      <div class="flex-1">
        <div class="font-bold text-primary text-sm">Труба {pipe.diameter}×{pipe.wallThickness} ВУС {city.namePrep}</div>
        <div class="text-xs text-text-muted mt-0.5">Изоляция ВУС, ГОСТ 9.602-2016</div>
      </div>
      <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>

  <ProductFAQ items={[
    { question: `Где купить трубу ${pipe.diameter}×${pipe.wallThickness} ${city.namePrep}?`, answer: `Оставьте заявку — подберём трубу ${pipe.diameter}×${pipe.wallThickness} от поставщиков ${city.namePrep} и ${city.region}.` },
    { question: `Какой вес трубы ${pipe.diameter}×${pipe.wallThickness}?`, answer: `Масса 1 м — <strong>${pipe.weightPerMeter} кг</strong> по ГОСТ 10704-91.` },
    { question: `Есть ли доставка ${city.namePrep}?`, answer: `Да, доставка по ${city.region}. Стоимость зависит от объёма.` },
  ]} />

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Труба ${pipe.diameter}×${pipe.wallThickness} ${city.namePrep}`} />
  </section>
</Gost>
