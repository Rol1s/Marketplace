---
import Gost from '@layouts/Gost.astro';
import GostTable from '@components/GostTable.astro';
import RelatedItems from '@components/RelatedItems.astro';
import BeamCrossSection from '@components/BeamCrossSection.astro';
import WeightCalculator from '@components/WeightCalculator';
import { getBeams, getBeamGostsForProfile } from '@lib/data';
import { beamMeta } from '@lib/seo';
import ProductFAQ from '@components/ProductFAQ.astro';
import ProductCrossLinks from '@components/ProductCrossLinks.astro';
import LeadForm from '@components/LeadForm.tsx';
import AddToCart from '@components/AddToCart.tsx';
import { relatedBeams } from '@lib/links';

export function getStaticPaths() {
  return getBeams().map((b) => ({
    params: { slug: b.slug },
    props: { beam: b },
  }));
}

const { beam } = Astro.props;
const allBeams = getBeams();
const meta = beamMeta(beam.profile, beam.weightPerMeter, beam.h);
const related = relatedBeams(allBeams, beam.slug);
const allGosts = getBeamGostsForProfile(beam.profile);
---

<Gost
  title={meta.title}
  description={meta.description}
  h1={`Двутавр ${beam.profile} — ГОСТ 35087-2024`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Двутавры', href: '/dvutavry/' },
    { label: beam.profile, href: `/dvutavry/${beam.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `BEAM-${beam.slug}`, weight: String(beam.weightPerMeter), gost: 'ГОСТ 35087-2024', category: 'Двутавры' }}
>
  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Размеры и масса</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
      <BeamCrossSection h={beam.h} b={beam.b} s={beam.s} t={beam.t} />
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-primary">{beam.h}</div>
          <div class="text-xs text-text-muted mt-1">Высота h, мм</div>
        </div>
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-primary">{beam.b}</div>
          <div class="text-xs text-text-muted mt-1">Полка b, мм</div>
        </div>
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-primary">{beam.s}/{beam.t}</div>
          <div class="text-xs text-text-muted mt-1">Стенка/полка, мм</div>
        </div>
        <div class="bg-surface rounded-lg p-4 text-center">
          <div class="text-2xl font-bold text-accent">{beam.weightPerMeter}</div>
          <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Механические характеристики</h2>
    <GostTable
      columns={[
        { key: 'param', label: 'Параметр' },
        { key: 'value', label: 'Значение', align: 'right' },
      ]}
      rows={[
        { param: 'Площадь сечения', value: `${beam.area} см²` },
        { param: 'Момент инерции Ix', value: `${beam.Ix} см⁴` },
        { param: 'Момент сопротивления Wx', value: `${beam.Wx} см³` },
        { param: 'Радиус инерции ix', value: `${beam.ix} см` },
        { param: 'Момент инерции Iy', value: `${beam.Iy} см⁴` },
        { param: 'Момент сопротивления Wy', value: `${beam.Wy} см³` },
        { param: 'Радиус инерции iy', value: `${beam.iy} см` },
      ]}
    />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Расчёт массы по длине</h2>
    <WeightCalculator
      client:visible
      productName={`Двутавр ${beam.profile}`}
      weightPerUnit={beam.weightPerMeter}
      mode="length"
      unitLabel="кг/м"
      defaultLength={6}
    />
  </section>

  {allGosts.length > 0 && (
    <section class="mb-8">
      <h2 class="text-lg font-bold text-primary mb-3">
        Профиль {beam.profile} в различных ГОСТах
      </h2>
      <GostTable
        columns={[
          { key: 'gost', label: 'ГОСТ / Стандарт' },
          { key: 'weightPerMeterKg', label: 'Масса', unit: 'кг/м', align: 'right' },
        ]}
        rows={allGosts}
      />
    </section>
  )}

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Область применения</h2>
    <p class="text-text-muted leading-relaxed">
      Двутавр {beam.profile} (высота {beam.h} мм, масса {beam.weightPerMeter} кг/м)
      {beam.profile.includes('Б') && ' — балка нормального типа. Применяется в строительных каркасах, перекрытиях, подкрановых балках.'}
      {beam.profile.includes('Ш') && ' — широкополочная балка. Используется в качестве колонн, стоек, ригелей в рамных конструкциях.'}
      {beam.profile.includes('К') && ' — колонный профиль. Оптимален для колонн зданий и сооружений благодаря повышенной устойчивости.'}
      {beam.profile.includes('ДБ') && ' — дополнительная серия балочного типа.'}
      {beam.profile.includes('ДК') && ' — дополнительная серия колонного типа.'}
    </p>
  </section>

  <ProductFAQ items={[
    { question: `Какой вес 1 метра двутавра ${beam.profile}?`, answer: `Масса 1 погонного метра двутавра ${beam.profile} по ГОСТ 35087-2024 составляет <strong>${beam.weightPerMeter} кг</strong>.` },
    { question: `Сколько двутавров ${beam.profile} в тонне?`, answer: `В 1 тонне ${beam.weightPerMeter > 0 ? (1000 / beam.weightPerMeter).toFixed(2) : '—'} погонных метров двутавра ${beam.profile} (${beam.weightPerMeter > 0 ? (1000 / (beam.weightPerMeter * 12)).toFixed(0) : '—'} штук по 12 м).` },
    { question: `Какой ГОСТ у двутавра ${beam.profile}?`, answer: `Двутавр ${beam.profile} изготавливается по <strong>ГОСТ 35087-2024</strong>. Стандарт определяет размеры, допуски и механические характеристики двутавровых балок.` },
    { question: `Где купить двутавр ${beam.profile}?`, answer: `Оставьте заявку — мы подберём лучшее предложение по двутавру ${beam.profile} от проверенных поставщиков. <a href="/zayavka/" class="text-primary underline">Оставить заявку</a>.` },
  ]} />

  <section class="mb-8">
    <a href="#lead-form" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg scroll-smooth">
      Оставить заявку на двутавр {beam.profile}
    </a>
  </section>

  <section class="mb-8">
    <a
      href={`/bu-metall/dvutavry/${beam.slug}/`}
      class="flex items-center gap-4 p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all bg-surface"
    >
      <div class="flex-1">
        <div class="font-bold text-primary">Двутавр {beam.profile} б/у</div>
        <div class="text-sm text-text-muted mt-0.5">Вторичный прокат — те же характеристики, экономия до 30–40%</div>
      </div>
      <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
    </a>
  </section>

  <ProductCrossLinks productSlug="dvutavry" itemSlug={beam.slug} productType={`двутавра ${beam.profile}`} basePath="/dvutavry/" />

  <RelatedItems title="Другие двутавры" items={related} />

  <section class="mb-8">
    <AddToCart client:visible id={beam.slug} category="dvutavry" name={`Двутавр ${beam.profile}`} gost="ГОСТ 35087-2024" weightPerMeter={beam.weightPerMeter} />
  </section>

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Двутавр ${beam.profile}`} />
  </section>
</Gost>
