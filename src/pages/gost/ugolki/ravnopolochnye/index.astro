---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import GostTable from '@components/GostTable.astro';
import { getAnglesEqual } from '@lib/data';
import { SITE } from '@/config/site';

const angles = getAnglesEqual();
const title = `Уголок равнополочный ГОСТ 8509-93 — сортамент, вес | ${SITE.name}`;
const description = `Сортамент равнополочных стальных уголков по ГОСТ 8509-93. ${angles.length} типоразмеров с таблицами массы и площади сечения.`;
---

<Base title={title} description={description}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs items={[
      { label: 'Справочник ГОСТ', href: '/gost/' },
      { label: 'Уголки', href: '/gost/ugolki/' },
      { label: 'Равнополочные', href: '/gost/ugolki/ravnopolochnye/' },
    ]} />

    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-4">
      Уголки равнополочные — ГОСТ 8509-93
    </h1>

    <p class="text-text-muted mb-8">{angles.length} типоразмеров.</p>

    <GostTable
      columns={[
        { key: 'size', label: 'Размер' },
        { key: 'aMm', label: 'Полка', unit: 'мм', align: 'right' },
        { key: 'thicknessMm', label: 'Толщина', unit: 'мм', align: 'right' },
        { key: 'crossSectionAreaMm2', label: 'Площадь', unit: 'мм²', align: 'right' },
        { key: 'massPerMeterKg', label: 'Масса', unit: 'кг/м', align: 'right' },
        { key: '_link', label: '' },
      ]}
      rows={angles.map((a) => ({
        ...a,
        _link: '→',
      }))}
    />

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 mt-8">
      {angles.map((a) => (
        <a
          href={`/gost/ugolki/ravnopolochnye/${a.slug}/`}
          class="group block p-3 rounded-lg border border-border hover:border-primary hover:shadow-md transition-all"
        >
          <div class="text-lg font-bold text-primary group-hover:text-accent">{a.size}</div>
          <div class="text-xs text-text-muted mt-1">{a.massPerMeterKg} кг/м</div>
        </a>
      ))}
    </div>
  </div>
</Base>
