---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import GostTable from '@components/GostTable.astro';
import { getPipes, getUniquePipeDiameters } from '@lib/data';
import { SITE } from '@/config/site';

const pipes = getPipes();
const diameters = getUniquePipeDiameters();

const title = `Трубы стальные электросварные ГОСТ 10704-91 — сортамент, вес | ${SITE.name}`;
const description = `Полный сортамент стальных электросварных труб по ГОСТ 10704-91. ${pipes.length} типоразмеров, диаметры от ${diameters[0]} до ${diameters[diameters.length - 1]} мм. Таблица весов, калькулятор массы.`;

const groupedByDiameter = diameters.map((d) => ({
  diameter: d,
  count: pipes.filter((p) => p.diameter === d).length,
  minWall: Math.min(...pipes.filter((p) => p.diameter === d).map((p) => p.wallThickness)),
  maxWall: Math.max(...pipes.filter((p) => p.diameter === d).map((p) => p.wallThickness)),
}));
---

<Base title={title} description={description}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs items={[
      { label: 'Справочник ГОСТ', href: '/gost/' },
      { label: 'Трубы', href: '/gost/truby/' },
    ]} />

    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-4">
      Трубы стальные электросварные — ГОСТ 10704-91
    </h1>

    <p class="text-text-muted mb-8 max-w-3xl">
      Полный сортамент электросварных стальных труб по ГОСТ 10704-91.
      {pipes.length} типоразмеров, диаметры от {diameters[0]} до {diameters[diameters.length - 1]} мм.
      Выберите диаметр для просмотра характеристик и расчёта веса.
    </p>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      {groupedByDiameter.map((g) => (
        <a
          href={`/gost/truby/${g.diameter}x${pipes.find((p) => p.diameter === g.diameter)!.wallThickness}/`}
          class="group block p-3 rounded-lg border border-border hover:border-primary hover:shadow-md transition-all"
        >
          <div class="text-lg font-bold text-primary group-hover:text-accent transition-colors">
            ⌀ {g.diameter}
          </div>
          <div class="text-xs text-text-muted mt-1">
            стенка {g.minWall}–{g.maxWall} мм
          </div>
          <div class="text-xs text-text-muted">
            {g.count} {g.count === 1 ? 'размер' : g.count < 5 ? 'размера' : 'размеров'}
          </div>
        </a>
      ))}
    </div>

    <section class="mt-12">
      <h2 class="text-xl font-bold text-primary mb-4">Полная таблица труб ГОСТ 10704-91</h2>
      <GostTable
        columns={[
          { key: 'diameter', label: 'Диаметр', unit: 'мм', align: 'right' },
          { key: 'wallThickness', label: 'Стенка', unit: 'мм', align: 'right' },
          { key: 'weightPerMeter', label: 'Масса 1 м', unit: 'кг', align: 'right' },
        ]}
        rows={pipes.map((p) => ({ ...p, _href: `/gost/truby/${p.slug}/` }))}
      />
    </section>
  </div>
</Base>
