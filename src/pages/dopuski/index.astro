---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import tolerances from '@/data/tolerances.json';
---

<Base
  title="Таблицы допусков по ГОСТам — допуски на металлопрокат | NikaMet"
  description="Допуски размеров стального металлопроката по ГОСТам: трубы, двутавры, швеллеры, уголки, листы, арматура, профильная труба, круг, полоса."
>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs items={[
      { label: 'Сортамент', href: '/sortament/' },
      { label: 'Таблицы допусков', href: '/dopuski/' },
    ]} />

    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-4">Таблицы допусков по ГОСТам</h1>
    <p class="text-text-muted mb-8 max-w-3xl">
      Допуски размеров стального металлопроката по действующим государственным стандартам.
      Для каждого ГОСТа указаны допускаемые отклонения при нормальной и повышенной точности.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tolerances.map((t) => (
        <a href={`/dopuski/${t.slug}/`}
          class="block p-5 bg-surface border border-border rounded-xl hover:border-primary hover:shadow-md transition-all group">
          <div class="font-bold text-sm group-hover:text-primary transition-colors">{t.productName}</div>
          <div class="text-xs text-accent font-mono mt-1">{t.gost}</div>
          <div class="text-xs text-text-muted mt-2">{t.parameters.length} параметров с допусками</div>
        </a>
      ))}
    </div>

    <section class="mt-12">
      <h2 class="text-lg font-bold text-primary mb-4">Что такое допуски?</h2>
      <div class="prose text-text-muted text-sm max-w-3xl space-y-3">
        <p>
          <strong>Допуск</strong> — это максимально допустимое отклонение реального размера от номинального,
          установленное ГОСТом. Различают нормальную и повышенную точность изготовления.
        </p>
        <p>
          Повышенная точность применяется для ответственных конструкций, где требуется минимальный зазор
          при сборке. Нормальная точность — стандартная для массового строительства.
        </p>
      </div>
    </section>

    <section class="mt-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/podbor/" class="block p-4 bg-surface border border-border rounded-xl hover:border-primary hover:shadow-md transition-all">
          <div class="font-bold text-sm">Подбор металла</div>
          <div class="text-xs text-text-muted mt-1">Визард подбора по нагрузке</div>
        </a>
        <a href="/nagruzki/" class="block p-4 bg-surface border border-border rounded-xl hover:border-primary hover:shadow-md transition-all">
          <div class="font-bold text-sm">Нагрузочные таблицы</div>
          <div class="text-xs text-text-muted mt-1">Допустимые нагрузки для профилей</div>
        </a>
        <a href="/calculator/" class="block p-4 bg-surface border border-border rounded-xl hover:border-primary hover:shadow-md transition-all">
          <div class="font-bold text-sm">Калькулятор массы</div>
          <div class="text-xs text-text-muted mt-1">Расчёт веса металлопроката</div>
        </a>
      </div>
    </section>
  </div>
</Base>
