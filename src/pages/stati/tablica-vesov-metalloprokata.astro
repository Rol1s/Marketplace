---
import Article from '@layouts/Article.astro';
import { SITE } from '@/config/site';
const title = `Сводная таблица весов всех видов металлопроката | ${SITE.name}`;
const description = 'Единая таблица масс погонного метра: трубы, швеллеры, двутавры, уголки, арматура, круг, квадрат, полоса.';
