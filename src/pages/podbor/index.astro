---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import MetalWizard from '@components/MetalWizard.tsx';
import { getBeams, getChannels, getPipes } from '@lib/data';

const beams = getBeams();
const channels = getChannels();
const pipes = getPipes();
---

<Base
  title="Подбор металлопроката — визард подбора балок, швеллеров, труб | NikaMet"
  description="Подбор металлопроката по нагрузке и пролёту с проверкой по прочности и прогибу. Двутавры, швеллеры, трубы — с расчётом запаса."
>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs items={[
      { label: 'Сортамент', href: '/sortament/' },
      { label: 'Подбор металла', href: '/podbor/' },
    ]} />

    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-2">Подбор металлопроката</h1>
    <p class="text-text-muted mb-8 max-w-2xl">
      Выберите задачу — балка, колонна, трубопровод или сваи — укажите параметры,
      и система подберёт профиль с расчётом запаса и возможностью скачать PDF-расчёт.
    </p>

    <MetalWizard client:visible beams={beams} channels={channels} pipes={pipes} />

    <section class="mt-12 space-y-6">
      <h2 class="text-lg font-bold text-primary">Методика расчёта</h2>
      <div class="prose text-text-muted text-sm max-w-3xl space-y-3">
        <p>
          <strong>Перекрытие / каркас (изгиб):</strong> Прочность — q<sub>max</sub> = 8 × Wx × Ry / L².
          Прогиб — f = 5qL⁴ / (384EIx) ≤ L/250 (перекрытие) или L/200 (каркас).
          Итог = min(по прочности, по прогибу).
        </p>
        <p>
          <strong>Колонна / сваи (устойчивость):</strong> Критическая сила Эйлера — N<sub>cr</sub> = π²EI / (μL)².
          Для колонн μ = 1.0, для свай μ = 2.0. Подбор по I<sub>min</sub> = min(Ix, Iy).
        </p>
        <p>
          <strong>Трубопровод (давление):</strong> Формула Барлоу — P = 2 × s × [σ] / D.
        </p>
        <p class="text-xs text-amber-600">
          Ry = 210 МПа (Ст3), E = 2,06 × 10⁵ МПа. Результаты — предварительный расчёт,
          для ответственных конструкций требуется проверка по СП 16.13330.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
        <a href="/nagruzki/" class="block p-4 bg-surface border border-border rounded-xl hover:border-primary hover:shadow-md transition-all">
          <div class="font-bold text-sm">Нагрузочные таблицы</div>
          <div class="text-xs text-text-muted mt-1">Допустимые нагрузки для каждого профиля</div>
        </a>
        <a href="/dopuski/" class="block p-4 bg-surface border border-border rounded-xl hover:border-primary hover:shadow-md transition-all">
          <div class="font-bold text-sm">Таблицы допусков</div>
          <div class="text-xs text-text-muted mt-1">Допуски размеров по ГОСТам</div>
        </a>
        <a href="/calculator/" class="block p-4 bg-surface border border-border rounded-xl hover:border-primary hover:shadow-md transition-all">
          <div class="font-bold text-sm">Калькулятор массы</div>
          <div class="text-xs text-text-muted mt-1">Расчёт веса труб, листов, профилей</div>
        </a>
      </div>
    </section>
  </div>
</Base>
