---
import Gost from '@layouts/Gost.astro';
import GostTable from '@components/GostTable.astro';
import RelatedItems from '@components/RelatedItems.astro';
import PipeCalculator from '@components/PipeCalculator';
import { getPipesSeamlessHot } from '@lib/data';
import { pipeSeamlessMeta } from '@lib/seo';
import ProductFAQ from '@components/ProductFAQ.astro';
import ProductCrossLinks from '@components/ProductCrossLinks.astro';
import LeadForm from '@components/LeadForm.tsx';

export function getStaticPaths() {
  return getPipesSeamlessHot().map((p) => ({
    params: { slug: p.slug },
    props: { item: p },
  }));
}

const { item } = Astro.props;
const allItems = getPipesSeamlessHot();
const meta = pipeSeamlessMeta(item.diameter, item.wallThickness, item.weightPerMeter);
const related = allItems
  .filter((p) => p.slug !== item.slug)
  .filter((p) => p.diameter === item.diameter || Math.abs(p.diameter - item.diameter) <= 10)
  .slice(0, 15)
  .map((p) => ({ label: `${p.diameter}×${p.wallThickness}`, href: `/truby-besshovnye/${p.slug}/` }));
---

<Gost
  title={meta.title}
  description={meta.description}
  h1={`Труба бесшовная ${item.diameter}×${item.wallThickness} — ГОСТ 8732-78`}
  breadcrumbs={[
    { label: 'Сортамент', href: '/sortament/' },
    { label: 'Трубы бесшовные', href: '/truby-besshovnye/' },
    { label: `${item.diameter}×${item.wallThickness}`, href: `/truby-besshovnye/${item.slug}/` },
  ]}
  schemaType="Product"
  productMeta={{ sku: `PSH-${item.slug}`, weight: String(item.weightPerMeter), gost: 'ГОСТ 8732-78', category: 'Трубы бесшовные' }}
>
  <section class="mb-8">
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{item.diameter}</div>
        <div class="text-xs text-text-muted mt-1">Диаметр, мм</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-primary">{item.wallThickness}</div>
        <div class="text-xs text-text-muted mt-1">Стенка, мм</div>
      </div>
      <div class="bg-surface rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-accent">{item.weightPerMeter}</div>
        <div class="text-xs text-text-muted mt-1">Масса, кг/м</div>
      </div>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Характеристики</h2>
    <GostTable
      columns={[{ key: 'param', label: 'Параметр' }, { key: 'value', label: 'Значение', align: 'right' }]}
      rows={[
        { param: 'Наружный диаметр', value: `${item.diameter} мм` },
        { param: 'Толщина стенки', value: `${item.wallThickness} мм` },
        { param: 'Масса 1 м', value: `${item.weightPerMeter} кг` },
        { param: 'Метров в тонне', value: `${(1000 / item.weightPerMeter).toFixed(1)} м` },
        { param: 'Тип', value: 'Бесшовная горячедеформированная' },
        { param: 'ГОСТ', value: item.gost },
      ]}
    />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Калькулятор веса</h2>
    <PipeCalculator client:visible diameter={item.diameter} wallThickness={item.wallThickness} />
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-bold text-primary mb-3">Область применения</h2>
    <p class="text-text-muted leading-relaxed">
      Бесшовная труба {item.diameter}×{item.wallThickness} по ГОСТ 8732-78 применяется в нефтегазовой промышленности, котельных установках, машиностроении, гидравлических системах. Отсутствие сварного шва обеспечивает повышенную прочность и герметичность при высоких давлениях и температурах.
    </p>
  </section>

  <ProductFAQ items={[
    { question: `Какой вес трубы бесшовной ${item.diameter}×${item.wallThickness}?`, answer: `Масса 1 м — <strong>${item.weightPerMeter} кг</strong> по ГОСТ 8732-78.` },
    { question: `Чем бесшовная труба отличается от электросварной?`, answer: `Бесшовная изготавливается без сварного шва методом горячей прокатки. Выдерживает более высокие давления и температуры.` },
  ]} />

  <section class="mb-8">
    <a href="#lead-form" class="block bg-accent hover:bg-accent/90 text-white text-center font-bold py-4 px-6 rounded-xl transition-colors text-lg">
      Заявка на бесшовную трубу {item.diameter}×{item.wallThickness}
    </a>
  </section>

  <section class="mb-8">
    <a href={`/truby/${item.slug}/`} class="flex items-center gap-4 p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all bg-surface">
      <div class="flex-1">
        <div class="font-bold text-primary">Электросварная труба {item.diameter}×{item.wallThickness}</div>
        <div class="text-sm text-text-muted mt-0.5">Сравнить с электросварной по ГОСТ 10704-91</div>
      </div>
      <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
    </a>
  </section>

  <RelatedItems title="Другие размеры бесшовных труб" items={related} />

  <section id="lead-form" class="scroll-mt-20">
    <LeadForm client:visible product={`Труба бесшовная ${item.diameter}×${item.wallThickness}`} />
  </section>
</Gost>
