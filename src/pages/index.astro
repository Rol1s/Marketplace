---
import Base from '@layouts/Base.astro';
import LeadForm from '@components/LeadForm';
import { getPipes, getChannels, getBeams, getSheets, getAnglesEqual, getAnglesUnequal, getSheetPiles } from '@lib/data';
import SectionIcon from '@components/SectionIcon.astro';
import { SITE, SECTIONS } from '@/config/site';

const counts: Record<string, number> = {
  truby: getPipes().length,
  shvellery: getChannels().length,
  dvutavry: getBeams().length,
  listy: getSheets().length,
  ugolki: getAnglesEqual().length + getAnglesUnequal().length,
  shpunt: getSheetPiles().length,
};

const total = Object.values(counts).reduce((a, b) => a + b, 0);

const gostLabels: Record<string, string> = {
  truby: 'ГОСТ 10704-91',
  shvellery: 'ГОСТ 8240-97',
  dvutavry: 'ГОСТ 35087-2024',
  listy: 'ГОСТ 19903-2015',
  ugolki: 'ГОСТ 8509 / 8510',
  shpunt: 'Arcelor, JFE',
};

const title = `${SITE.name} — ГОСТ-справочник металлопроката с калькулятором веса`;
const description = SITE.description;
---

<Base title={title} description={description}>
  <!-- Hero -->
  <section class="bg-primary text-white py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-4 leading-tight">
        Справочник металлопроката<br />с точными данными по ГОСТ
      </h1>
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-8">
        {total} типоразмеров. Таблицы характеристик, калькулятор веса,
        механические свойства. Всё в одном месте.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/sortament/"
          class="px-8 py-3 bg-white text-primary font-bold rounded-lg hover:bg-surface transition-colors"
        >
          Открыть справочник
        </a>
        <a
          href="/podbor/"
          class="px-8 py-3 bg-accent text-white font-bold rounded-lg hover:bg-accent-light transition-colors"
        >
          Подбор металла
        </a>
        <a
          href="/calculator/"
          class="px-8 py-3 border-2 border-white text-white font-bold rounded-lg hover:bg-white/10 transition-colors"
        >
          Калькулятор веса
        </a>
      </div>
    </div>
  </section>

  <!-- Sections Grid -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold text-primary mb-8 text-center">
      Сортамент по ГОСТам
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {SECTIONS.map((section) => (
        <a
          href={`/${section.slug}/`}
          class="group block p-6 rounded-xl border-2 border-border hover:border-primary hover:shadow-lg transition-all"
        >
          <SectionIcon slug={section.slug} class="w-10 h-10 mb-3 text-primary group-hover:text-accent transition-colors" />
          <h3 class="text-xl font-bold text-primary group-hover:text-accent transition-colors">
            {section.name}
          </h3>
          <p class="text-sm text-text-muted mt-1">{gostLabels[section.slug]}</p>
          <p class="text-sm font-semibold text-primary mt-3">
            {counts[section.slug]} типоразмеров
          </p>
        </a>
      ))}
    </div>
  </section>

  <!-- New product categories -->
  <section class="max-w-5xl mx-auto px-4 pt-12 pb-4">
    <h2 class="text-2xl font-bold text-primary mb-6 text-center">Все виды проката</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      <a href="/armatura/" class="group block p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Арматура</h3>
        <p class="text-xs text-text-muted mt-1">ГОСТ 34028-2016</p>
      </a>
      <a href="/profilnaya-truba/" class="group block p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Профильная труба</h3>
        <p class="text-xs text-text-muted mt-1">ГОСТ 8639 / 8645</p>
      </a>
      <a href="/truby-besshovnye/" class="group block p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Трубы бесшовные</h3>
        <p class="text-xs text-text-muted mt-1">ГОСТ 8732-78</p>
      </a>
      <a href="/truby-vgp/" class="group block p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Трубы ВГП</h3>
        <p class="text-xs text-text-muted mt-1">ГОСТ 3262-75</p>
      </a>
      <a href="/krug/" class="group block p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Круг стальной</h3>
        <p class="text-xs text-text-muted mt-1">ГОСТ 2590-2006</p>
      </a>
      <a href="/kvadrat/" class="group block p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Квадрат стальной</h3>
        <p class="text-xs text-text-muted mt-1">ГОСТ 2591-88</p>
      </a>
      <a href="/polosa/" class="group block p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Полоса стальная</h3>
        <p class="text-xs text-text-muted mt-1">ГОСТ 103-2006</p>
      </a>
      <a href="/dvutavry-8239/" class="group block p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Двутавры ГОСТ 8239</h3>
        <p class="text-xs text-text-muted mt-1">С уклоном полок</p>
      </a>
      <a href="/shvellery-gnutye/" class="group block p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Швеллеры гнутые</h3>
        <p class="text-xs text-text-muted mt-1">ГОСТ 8278-83</p>
      </a>
    </div>
  </section>

  <!-- Инструменты -->
  <section class="max-w-5xl mx-auto px-4 pt-8 pb-4">
    <h2 class="text-2xl font-bold text-primary mb-6 text-center">Инструменты</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <a href="/podbor/" class="group block p-5 rounded-xl border-2 border-primary/30 hover:border-primary hover:shadow-lg transition-all bg-primary/5">
        <h3 class="font-bold text-primary group-hover:text-accent">Подбор металла</h3>
        <p class="text-xs text-text-muted mt-1">Визард: задача → профиль</p>
      </a>
      <a href="/nagruzki/" class="group block p-5 rounded-xl border-2 border-primary/30 hover:border-primary hover:shadow-lg transition-all bg-primary/5">
        <h3 class="font-bold text-primary group-hover:text-accent">Нагрузочные таблицы</h3>
        <p class="text-xs text-text-muted mt-1">610+ таблиц нагрузок</p>
      </a>
      <a href="/dopuski/" class="group block p-5 rounded-xl border-2 border-primary/30 hover:border-primary hover:shadow-lg transition-all bg-primary/5">
        <h3 class="font-bold text-primary group-hover:text-accent">Таблицы допусков</h3>
        <p class="text-xs text-text-muted mt-1">14 ГОСТов</p>
      </a>
      <a href="/smeta" class="group block p-5 rounded-xl border-2 border-primary/30 hover:border-primary hover:shadow-lg transition-all bg-primary/5">
        <h3 class="font-bold text-primary group-hover:text-accent">Смета</h3>
        <p class="text-xs text-text-muted mt-1">Собери позиции → скачай PDF</p>
      </a>
    </div>
  </section>

  <!-- Спецразделы -->
  <section class="max-w-5xl mx-auto px-4 pt-8 pb-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <a href="/bu-metall/" class="group block p-5 rounded-xl border-2 border-border hover:border-primary hover:shadow-lg transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Б/у металлопрокат</h3>
        <p class="text-xs text-text-muted mt-1">Экономия до 40%</p>
      </a>
      <a href="/truby/izolyaciya-vus/" class="group block p-5 rounded-xl border-2 border-border hover:border-primary hover:shadow-lg transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">ВУС изоляция</h3>
        <p class="text-xs text-text-muted mt-1">⌀219–1420 мм</p>
      </a>
      <a href="/stati/" class="group block p-5 rounded-xl border-2 border-border hover:border-primary hover:shadow-lg transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Статьи и гайды</h3>
        <p class="text-xs text-text-muted mt-1">10 экспертных материалов</p>
      </a>
      <a href="/sravnenie/" class="group block p-5 rounded-xl border-2 border-border hover:border-primary hover:shadow-lg transition-all">
        <h3 class="font-bold text-primary group-hover:text-accent">Сравнение ГОСТов</h3>
        <p class="text-xs text-text-muted mt-1">5 таблиц сравнения</p>
      </a>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-surface py-16">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-primary mb-8 text-center">
        Чем полезен {SITE.name}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-3 text-primary">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="6" width="36" height="36" rx="3"/>
              <line x1="6" y1="18" x2="42" y2="18"/><line x1="6" y1="30" x2="42" y2="30"/>
              <line x1="18" y1="6" x2="18" y2="42"/><line x1="30" y1="6" x2="30" y2="42"/>
            </svg>
          </div>
          <h3 class="font-bold text-primary mb-2">Точные данные</h3>
          <p class="text-sm text-text-muted">
            Все характеристики из действующих ГОСТов.
            Размеры, масса, моменты инерции и сопротивления.
          </p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-3 text-primary">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="10" y="4" width="28" height="40" rx="3"/>
              <rect x="14" y="10" width="20" height="10" rx="1" fill="currentColor" opacity="0.1"/>
              <line x1="14" y1="26" x2="22" y2="26"/><line x1="26" y1="26" x2="34" y2="26"/>
              <line x1="14" y1="32" x2="22" y2="32"/><line x1="26" y1="32" x2="34" y2="32"/>
              <line x1="14" y1="38" x2="22" y2="38"/><line x1="26" y1="38" x2="34" y2="38"/>
            </svg>
          </div>
          <h3 class="font-bold text-primary mb-2">Калькулятор веса</h3>
          <p class="text-sm text-text-muted">
            Мгновенный расчёт массы трубы, листа, профиля.
            Формулы по ГОСТ, плотность стали 7850 кг/м³.
          </p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-3 text-primary">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="20" cy="20" r="12"/><line x1="28.5" y1="28.5" x2="40" y2="40"/>
              <path d="M16 20h8M20 16v8"/>
            </svg>
          </div>
          <h3 class="font-bold text-primary mb-2">Подбор металла</h3>
          <p class="text-sm text-text-muted">
            Оставьте заявку — подберём нужный металлопрокат
            по вашим требованиям.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Lead Form -->
  <section class="max-w-2xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold text-primary mb-6 text-center">
      Нужен металлопрокат?
    </h2>
    <LeadForm client:visible source="homepage" />
  </section>

  <!-- FAQ -->
  <section class="max-w-3xl mx-auto px-4 pb-16">
    <h2 class="text-2xl font-bold text-primary mb-6">Частые вопросы</h2>
    <div class="space-y-4">
      <details class="border border-border rounded-lg p-4 group">
        <summary class="font-medium text-primary cursor-pointer">
          Откуда данные по сортаменту?
        </summary>
        <p class="text-sm text-text-muted mt-2">
          Все данные взяты из действующих ГОСТов: 10704-91 (трубы), 8240-97 (швеллеры),
          35087-2024 (двутавры), 19903-2015 (листы), 8509-93 и 8510-86 (уголки).
          Данные по шпунту — из каталогов производителей (Arcelor, JFE, Larssen).
        </p>
      </details>
      <details class="border border-border rounded-lg p-4">
        <summary class="font-medium text-primary cursor-pointer">
          Как рассчитывается вес?
        </summary>
        <p class="text-sm text-text-muted mt-2">
          Для труб: M = π × (D − s) × s × ρ × L, где ρ = 7850 кг/м³.
          Для листов: M = t × W × L × ρ.
          Для профилей (швеллер, двутавр, уголок): масса = масса 1 м по ГОСТ × длина.
        </p>
      </details>
      <details class="border border-border rounded-lg p-4">
        <summary class="font-medium text-primary cursor-pointer">
          Вы продаёте металл?
        </summary>
        <p class="text-sm text-text-muted mt-2">
          {SITE.name} — справочный ресурс. Мы помогаем подобрать поставщика.
          Оставьте заявку с описанием того что нужно, и мы свяжем вас с продавцом.
        </p>
      </details>
    </div>
  </section>
</Base>
