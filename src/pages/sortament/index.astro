---
import Base from '@layouts/Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { getPipes, getChannels, getBeams, getSheets, getAnglesEqual, getAnglesUnequal, getSheetPiles } from '@lib/data';
import SectionIcon from '@components/SectionIcon.astro';
import { SITE, SECTIONS } from '@/config/site';

const counts = {
  truby: getPipes().length,
  shvellery: getChannels().length,
  dvutavry: getBeams().length,
  listy: getSheets().length,
  ugolki: getAnglesEqual().length + getAnglesUnequal().length,
  shpunt: getSheetPiles().length,
};

const total = Object.values(counts).reduce((a, b) => a + b, 0);

const gostLabels: Record<string, string> = {
  truby: 'ГОСТ 10704-91',
  shvellery: 'ГОСТ 8240-97',
  dvutavry: 'ГОСТ 35087-2024',
  listy: 'ГОСТ 19903-2015',
  ugolki: 'ГОСТ 8509-93 / 8510-86',
  shpunt: 'Arcelor, JFE, Larssen',
};

const title = `Справочник ГОСТ по металлопрокату — ${total} типоразмеров | ${SITE.name}`;
const description = `ГОСТ-справочник металлопроката: трубы, швеллеры, двутавры, листы, уголки, шпунт Ларсена. ${total} типоразмеров с таблицами характеристик и калькулятором веса.`;
---

<Base title={title} description={description}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs items={[
      { label: 'Справочник ГОСТ', href: '/sortament/' },
    ]} />

    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-4">
      Справочник ГОСТ по металлопрокату
    </h1>

    <p class="text-text-muted mb-8 max-w-3xl">
      {total} типоразмеров металлопроката с точными характеристиками по действующим ГОСТам.
      Таблицы размеров, масса погонного метра, механические свойства, калькулятор веса.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {SECTIONS.map((section) => {
        const count = counts[section.slug as keyof typeof counts] || 0;
        return (
          <a
            href={`/${section.slug}/`}
            class="group block p-6 rounded-xl border-2 border-border hover:border-primary hover:shadow-lg transition-all"
          >
            <SectionIcon slug={section.slug} class="w-10 h-10 mb-3 text-primary group-hover:text-accent transition-colors" />
            <h2 class="text-xl font-bold text-primary group-hover:text-accent transition-colors">
              {section.name}
            </h2>
            <p class="text-sm text-text-muted mt-1">{gostLabels[section.slug]}</p>
            <p class="text-sm font-medium text-primary mt-3">
              {count} {count === 1 ? 'типоразмер' : count < 5 ? 'типоразмера' : 'типоразмеров'}
            </p>
          </a>
        );
      })}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-8">
      <a href="/bu-metall/" class="p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all bg-surface flex items-center gap-3">
        <div class="flex-1">
          <div class="font-bold text-primary">Б/у металлопрокат</div>
          <div class="text-xs text-text-muted mt-0.5">Вторичный прокат по ГОСТ — экономия до 40%</div>
        </div>
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="/truby/izolyaciya-vus/" class="p-4 rounded-xl border border-border hover:border-primary hover:shadow-md transition-all bg-surface flex items-center gap-3">
        <div class="flex-1">
          <div class="font-bold text-primary">Трубы в изоляции ВУС</div>
          <div class="text-xs text-text-muted mt-0.5">⌀219–1420 мм, ГОСТ 9.602-2016</div>
        </div>
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</Base>
