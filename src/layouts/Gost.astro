---
import Base from './Base.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import SchemaMarkup from '@components/SchemaMarkup.astro';

interface Crumb {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  h1: string;
  breadcrumbs: Crumb[];
  schemaType?: 'TechArticle' | 'Product';
}

const { title, description, h1, breadcrumbs, schemaType = 'TechArticle' } = Astro.props;
---

<Base title={title} description={description} ogType="article">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <h1 class="text-2xl md:text-3xl font-bold text-primary mb-6">{h1}</h1>

    <slot />
  </div>

  <SchemaMarkup
    type={schemaType}
    name={h1}
    description={description}
    url={Astro.url.pathname}
  />
</Base>
